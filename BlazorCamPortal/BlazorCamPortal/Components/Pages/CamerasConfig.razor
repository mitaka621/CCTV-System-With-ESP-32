@page "/camerasConfig"
@using CamPortal.Contracts.Enums
@rendermode InteractiveServer

@inject ICameraService _cameraService
@inject IDialogService DialogService
@inject IDevicePairHttpService _devicePairHttpService

<PageTitle>Camera Configuration - BlazorCam Portal</PageTitle>

<MudText Typo="Typo.h3" Class="mb-4" Color="Color.Primary">
    <MudIcon Icon="@Icons.Material.Filled.Settings" Class="mr-3" />
    Camera Configuration
</MudText>


<MudPaper Elevation="4" Class="pa-6 mb-6" Style="position:relative">
    <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <div>
            <MudText Typo="Typo.h5" Color="Color.Secondary" Class="mb-2">
                <MudIcon Icon="@Icons.Material.Filled.Search" Class="mr-2" />
                Device Discovery
            </MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary">
                Scan your local network for new ESP32 camera devices
            </MudText>
        </div>
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Primary" 
                   Size="Size.Large"
                   StartIcon="@Icons.Material.Filled.Scanner"
                   OnClick="ScanAndAddNewCameras"
                   Disabled="isScanning">
            @if (isScanning)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <text>Scanning...</text>
            }
            else
            {
                <text>Scan Network</text>
            }
        </MudButton>
    </MudStack>

    @if (isScanning)
    {
        <MudAlert Severity="Severity.Info" NoIcon="true" ContentAlignment="HorizontalAlignment.Center">
            <MudText Typo="Typo.body1">
                <MudIcon Icon="@Icons.Material.Filled.Wifi" Class="mr-2" />
                Scanning network for ESP32 devices... This may take a moment.
            </MudText>
        </MudAlert>      
    }
    else
    {
        if (foundDeviceIds != null && foundDeviceIds.Count > 0)
        {
            <MudAlert Severity="Severity.Success" NoIcon="true" ContentAlignment="HorizontalAlignment.Center" Class="mb-4">
                <MudText Typo="Typo.body1">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Class="mr-2" />
                    Scan complete! Found @(foundDeviceIds.Count) new device(s).
                </MudText>
            </MudAlert>
        }
        else if (foundDeviceIds != null)
        {
            <MudAlert Severity="Severity.Error" NoIcon="true" ContentAlignment="HorizontalAlignment.Center" Class="mb-4">
                <MudText Typo="Typo.body1">
                    <MudIcon Icon="@Icons.Material.Filled.Error" Class="mr-2" />
                    Scan complete! Did not find any new devices.
                </MudText>
            </MudAlert>
        }
    }
    @if (isScanning)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Style="position:absolute !important; bottom:0 !important; right:0" />
    }
</MudPaper>

<!-- Camera List -->
<MudText Typo="Typo.h4" Class="mb-4" Color="Color.Secondary">
    <MudIcon Icon="@Icons.Material.Filled.Videocam" Class="mr-2" />
    Detected Cameras (@cameraDisplayModels.Count)
</MudText>

@if (cameraDisplayModels.Count == 0)
{
    <MudPaper Elevation="2" Class="pa-8 text-center">
        <MudIcon Icon="@Icons.Material.Outlined.VideocamOff" Size="Size.Large" Color="Color.Secondary" Class="mb-4" />
        <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mb-2">No Cameras Found</MudText>
        <MudText Typo="Typo.body1" Color="Color.Secondary">
            Use the scan feature above to discover cameras on your network
        </MudText>
    </MudPaper>
}
else
{
    <MudGrid>
        @foreach (var camera in cameraDisplayModels)
        {
            <MudItem xs="12" md="6" lg="4" @key="camera.Id">
                <MudCard Elevation="6" Class="camera-config-card">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <div class="d-flex align-center justify-space-between">
                                <div>
                                    <MudText Typo="Typo.h6">
                                        <MudIcon Icon="@Icons.Material.Filled.Videocam" Size="Size.Small" Class="mr-2" />
                                        @(camera.Name ?? "Unnamed Camera")
                                    </MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        ID: @camera.Id
                                    </MudText>
                                </div>
                                <MudChip T="string" Color="@GetStatusColor(camera.PairStatus)" 
                                        Size="Size.Small" 
                                        Icon="@GetStatusIcon(camera.PairStatus)">
                                    @camera.PairStatus
                                </MudChip>
                            </div>
                        </CardHeaderContent>
                    </MudCardHeader>
                    
                    <MudCardContent>
                        <MudStack Spacing="2">
                            <div class="d-flex align-center">
                                <MudIcon Icon="@Icons.Material.Filled.NetworkWifi" Size="Size.Small" Class="mr-2" Color="Color.Secondary" />
                                <MudText Typo="Typo.body2">
                                    <strong>IP:</strong> @camera.Ipv4Address
                                </MudText>
                            </div>
                            <div class="d-flex align-center">
                                <MudIcon Icon="@Icons.Material.Filled.Router" Size="Size.Small" Class="mr-2" Color="Color.Secondary" />
                                <MudText Typo="Typo.body2">
                                    <strong>MAC:</strong> @camera.MacAddress
                                </MudText>
                            </div>
                            <div class="d-flex align-center">
                                <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="mr-2" Color="Color.Secondary" />
                                <MudText Typo="Typo.body2">
                                    <strong>Added:</strong> @camera.CreatedAt.ToString("MMM dd, yyyy")
                                </MudText>
                            </div>
                        </MudStack>
                    </MudCardContent>
                    
                    <MudCardActions Class="d-flex justify-space-between">
                        @if (camera.PairStatus != PairStatus.Forgotten)
                        {
                            <MudButton StartIcon="@Icons.Material.Filled.Edit" 
                                     Color="Color.Secondary" 
                                     Size="Size.Small"
                                     Variant="Variant.Text">
                                Configure
                            </MudButton>
                            <MudButton StartIcon="@Icons.Material.Filled.Delete" 
                                     Color="Color.Error" 
                                     Size="Size.Small"
                                     Variant="Variant.Text"
                                       OnClick="() => ShowForgetDialog(camera)">
                                Forget
                            </MudButton>
                        }
                        else
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Device forgotten</MudText>
                            <MudButton StartIcon="@Icons.Material.Filled.Restore" 
                                     Color="Color.Primary" 
                                     Size="Size.Small"
                                     Variant="Variant.Text">
                                Restore
                            </MudButton>
                        }
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {
	bool isScanning;
	List<CameraDisplayModel> cameraDisplayModels = new();
	List<Guid>? foundDeviceIds;

	protected override async Task OnInitializedAsync()
	{
		cameraDisplayModels=await _cameraService.GetAllCamerasAsync();
	}

	private async Task ScanAndAddNewCameras()
	{
		if (isScanning)
			return;

		isScanning = true;
		foundDeviceIds = null;

		StateHasChanged();

		await Task.Yield();

		try
		{
			foundDeviceIds = await _devicePairHttpService.SendChallengeToAllDevicesAsync();
			cameraDisplayModels = await _cameraService.GetAllCamerasAsync();
		}
		finally
		{
			isScanning = false;
		}
	}

	private async Task ForgetCamera(Guid cameraId)
	{
        await _cameraService.ChangeCameraStatusAsync(cameraId, PairStatus.Forgotten);

		cameraDisplayModels.First(x => x.Id == cameraId).PairStatus = PairStatus.Forgotten;
		StateHasChanged();
	}

	private Color GetStatusColor(PairStatus status)
	{
		return status switch
		{
			PairStatus.Paired => Color.Success,
			PairStatus.Forgotten => Color.Error,
			PairStatus.ServerChallengeSolved => Color.Info,
			PairStatus.ServerChallengeFailed => Color.Warning,
			PairStatus.SessionTokenExpired => Color.Warning,
			_ => Color.Default
		};
	}

	private string GetStatusIcon(PairStatus status)
	{
		return status switch
		{
			PairStatus.Paired => Icons.Material.Filled.CheckCircle,
			PairStatus.Forgotten => Icons.Material.Filled.Cancel,
			PairStatus.ServerChallengeSolved => Icons.Material.Filled.Check,
			PairStatus.ServerChallengeFailed => Icons.Material.Filled.Error,
			PairStatus.SessionTokenExpired => Icons.Material.Filled.Schedule,
			_ => Icons.Material.Filled.Help
		};
	}

    private async Task ShowForgetDialog(CameraDisplayModel camera)
    {
        bool? result = await DialogService.ShowMessageBox(
            "Confirm Delete",
            (MarkupString)$"Are you sure you want to forget <b>{camera.Name??camera.Id.ToString()}</b>?",
            yesText: "Yes",
            cancelText: "Cancel"
        );

        if (result == true)
        {
            await ForgetCamera(camera.Id);
        }
    }
}

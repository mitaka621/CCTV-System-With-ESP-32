@page "/"
@implements IDisposable
@rendermode InteractiveServer

@inject ICameraService _cameraService
@inject ICameraFramesManagerService _cameraFramesManagerService
@inject IJSRuntime JS
@inject IConfiguration _configuration
@inject IDialogService _dialogService

<PageTitle>Dashboard - BlazorCam Portal</PageTitle>

<Dashboard></Dashboard>

<MudText Typo="Typo.h4" Class="mb-4" Color="Color.Secondary">
    <MudIcon Icon="@Icons.Material.Filled.GridView" Class="mr-2 icon-to-hide-on-mobile" />
    Live Camera Feeds
</MudText>

@if (cameras.Count == 0)
{
    <MudPaper Elevation="2" Class="pa-8 text-center">
        <MudIcon Icon="@Icons.Material.Outlined.VideocamOff" Size="Size.Large" Color="Color.Secondary" Class="mb-4" />
        <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mb-2">No Cameras Connected</MudText>
        <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-4">Get started by configuring your first camera</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Href="/camerasConfig">
            Configure Cameras
        </MudButton>
    </MudPaper>
}
else
{
    <MudGrid>
        @foreach (var camera in cameras)
        {
            <MudItem xs="12" sm="6" md="6" lg="4" xl="3" @key="camera.Id">
                <MudCard Elevation="6" Class="camera-card">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <div class="d-flex align-center justify-space-between">
                                <div class="camera-info-container">
                                    <MudTooltip Text="@GetCameraDisplayName(camera)" 
                                              Placement="Placement.Top"
                                              ShowOnFocus="false"
                                              ShowOnHover="true"
                                              Class="camera-name-tooltip">
                                        <MudText Typo="Typo.body1" Class="camera-name-text">
                                            <MudIcon Icon="@Icons.Material.Filled.Videocam" Size="Size.Small" Class="mr-2" />
                                            <span class="camera-name-span">@GetCameraDisplayName(camera)</span>
                                        </MudText>
                                    </MudTooltip>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        @camera.Ipv4Address
                                    </MudText>
                                </div>
                                <MudChip T="string" Color="Color.Success" Size="Size.Small" Icon="@Icons.Material.Filled.FiberManualRecord">
                                    Live
                                </MudChip>
                            </div>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent Class="pa-0">
                        <div class="camera-container">
                            <canvas id="@camera.Id" width="1280" height="720" class="camera-canvas"></canvas>
                            <div class="camera-overlay">
                                <MudIconButton Icon="@Icons.Material.Filled.Fullscreen" 
                                             Color="Color.Primary" 
                                             Size="Size.Large"
                                             Class="fullscreen-btn"
                                             OnClick="() => OpenFullScreen(camera)" />
                            </div>
                        </div>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton StartIcon="@Icons.Material.Filled.PhotoCamera" Color="Color.Secondary" Size="Size.Small">
                            Snapshot
                        </MudButton>
                        <MudSpacer />
                        <MudIconButton Icon="@Icons.Material.Filled.Settings" Color="Color.Default" Size="Size.Small" />
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}


@code {
    private List<CameraDisplayModel> cameras = new();
    private int connectedCameras = 0;
    private Task _initialLoadTask = Task.CompletedTask;

    protected override async Task OnInitializedAsync()
    {
        _initialLoadTask = LoadCamerasAsync();
        await _initialLoadTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {   
            await _initialLoadTask;

            foreach (var camera in cameras)
            {
                await OnFrameAdded(camera.Id, VideoChunkUtilities.GetDefaultFrame(_configuration));
            }

            _cameraFramesManagerService.FrameProcessed += OnFrameAdded;
        }
    }

    private async Task LoadCamerasAsync()
    {
        cameras = await _cameraService.GetAllCamerasAsync(Contracts.Enums.PairStatus.Paired);
        connectedCameras = cameras.Count;
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnFrameAdded(Guid cameraId, byte[] frame)
    {
        try
        {
            using var stream = new MemoryStream(frame);
            using var streamRef = new DotNetStreamReference(stream);

            await JS.InvokeVoidAsync("drawFrame", cameraId.ToString(), streamRef);
        }
        catch (TaskCanceledException)
        {
            // No action needed, the task was canceled because the component is being disposed
        }
        catch (ObjectDisposedException)
        {
            // No action needed, the stream was disposed because the component is being disposed
        }
    }

    private async Task OpenFullScreen(CameraDisplayModel camera)
    {
        var parameters = new DialogParameters
        {
            ["Camera"] = camera,
            ["CameraFramesManagerService"] = _cameraFramesManagerService
        };

        var options = new DialogOptions()
        {
            MaxWidth = MaxWidth.False,
            FullWidth = true,
            CloseButton = false,
            NoHeader = true,
            CloseOnEscapeKey = true
        };

        await _dialogService.ShowAsync<FullscreenCameraDialog>("", parameters, options);
    }

    public void Dispose()
    {
        _cameraFramesManagerService.FrameProcessed -= OnFrameAdded;
    }

    private string GetCameraDisplayName(CameraDisplayModel camera)
    {
        if (!string.IsNullOrEmpty(camera.Name))
            return camera.Name;

        return $"{camera.Id}";
    }
}

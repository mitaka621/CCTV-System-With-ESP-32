<AuthorizeView>
    <Authorized>
        <MudMenu AnchorOrigin="Origin.BottomRight"
                 TransformOrigin="Origin.TopRight"
                 Dense="true"
                 PopoverClass="user-menu-popover">
            <ActivatorContent>
                <MudAvatar Color="Color.Primary"
                           Size="Size.Medium"
                           Class="user-menu-avatar">
                    @GetInitial(context.User.Identity?.Name)
                </MudAvatar>
            </ActivatorContent>
            <ChildContent>
                <div class="user-menu-header">
                    <MudText Typo="Typo.subtitle2" Class="user-menu-name">
                        @context.User.Identity?.Name
                    </MudText>
                </div>
                <MudDivider />
                <MudMenuItem Icon="@Icons.Material.Filled.ManageAccounts"
                             Href="/account/settings">
                    User Settings
                </MudMenuItem>
                <MudDivider />
                <div class="user-menu-logout">
                    <form method="post" action="/api/auth/logout" onsubmit="window.showSubmitOverlay()">
                        <AntiforgeryToken />
                        <MudButton ButtonType="ButtonType.Submit"
                                   StartIcon="@Icons.Material.Filled.Logout"
                                   FullWidth="true"
                                   Variant="Variant.Text"
                                   Color="Color.Error">
                            Logout
                        </MudButton>
                    </form>
                </div>
            </ChildContent>
        </MudMenu>
    </Authorized>
</AuthorizeView>

<style>
    .user-menu-avatar {
        cursor: pointer;
        font-weight: 600;
        font-size: 1rem;
        border: 2px solid rgba(255, 255, 255, 0.15);
        transition: all 0.2s ease;
    }

    .user-menu-avatar:hover {
        transform: scale(1.05);
        border-color: var(--mud-palette-primary);
    }

    .user-menu-popover {
        min-width: 220px;
    }

    .user-menu-header {
        padding: 12px 16px 8px 16px;
    }

    .user-menu-name {
        font-weight: 600;
    }

    .user-menu-logout {
        padding: 4px 8px 8px 8px;
    }

    .user-menu-logout form {
        margin: 0;
    }
</style>

@code {
    private static string GetInitial(string? name)
    {
        return string.IsNullOrWhiteSpace(name)
            ? "?"
            : name.Trim()[..1].ToUpperInvariant();
    }
}

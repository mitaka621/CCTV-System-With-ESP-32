@page "/change-password"
@layout AuthLayout
@using CamPortal.Components.Layout
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]

<PageTitle>Change Password - BlazorCam Portal</PageTitle>

<MudPaper Elevation="6" Class="pa-8" Style="width: 100%; max-width: 480px;">
    <MudStack Spacing="4">
        <MudStack AlignItems="AlignItems.Center" Spacing="1">
            <MudIcon Icon="@Icons.Material.Filled.LockReset" Size="Size.Large" Color="Color.Primary" />
            <MudText Typo="Typo.h5" Align="Align.Center">Set a new password</MudText>
            @if (_isFirstTime)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                    You must change your initial password before continuing.
                </MudText>
            }
        </MudStack>

        @if (Error == "invalid")
        {
            <MudAlert Severity="Severity.Error">
                Password must be 6+ characters and contain uppercase, lowercase and a number. Both fields must match.
            </MudAlert>
        }
        else if (Error == "invalid-old")
        {
            <MudAlert Severity="Severity.Error">Incorrect old password.</MudAlert>
        }
        else if (Error == "failed")
        {
            <MudAlert Severity="Severity.Error">Something went wrong saving the new password.</MudAlert>
        }

        <form method="post" action="/api/auth/change-password" onsubmit="window.showSubmitOverlay()">
            <AntiforgeryToken />

            <MudStack Spacing="3">
                @if (!_isFirstTime)
                {
                    <MudTextField T="string"
                                  Label="Current password"
                                  InputType="InputType.Password"
                                  Variant="Variant.Filled"
                                  Required="true"
                                  AutoFocus="true"
                                  UserAttributes="@_oldPasswordAttributes" />
                }
                <MudTextField T="string"
                              Label="New password"
                              InputType="InputType.Password"
                              Variant="Variant.Filled"
                              Required="true"
                              AutoFocus="@_isFirstTime"
                              HelperText="6+ chars, uppercase, lowercase and number"
                              UserAttributes="@_newPasswordAttributes" />

                <MudTextField T="string"
                              Label="Confirm password"
                              InputType="InputType.Password"
                              Variant="Variant.Filled"
                              Required="true"
                              UserAttributes="@_confirmPasswordAttributes" />

                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large">
                    Save and continue
                </MudButton>
            </MudStack>
        </form>
    </MudStack>
</MudPaper>

@code {
    [CascadingParameter] private HttpContext? HttpContext { get; set; }

    [SupplyParameterFromQuery(Name = "error")] public string? Error { get; set; }

    private bool _isFirstTime;

    protected override async Task OnInitializedAsync()
    {
        if (HttpContext is null)
        {
            return;
        }

        var mainAuth = await HttpContext.AuthenticateAsync(
            CookieAuthenticationDefaults.AuthenticationScheme);

        var pendingAuth = await HttpContext.AuthenticateAsync(
            AuthSchemes.PasswordChangePending);

        if (!mainAuth.Succeeded && !pendingAuth.Succeeded)
        {
            HttpContext.Response.Redirect("/login?error=expired");
            return;
        }

        _isFirstTime = !mainAuth.Succeeded;
    }

    private readonly Dictionary<string, object?> _newPasswordAttributes = new()
    {
        ["name"] = "NewPassword",
        ["autocomplete"] = "new-password"
    };

    private readonly Dictionary<string, object?> _confirmPasswordAttributes = new()
    {
        ["name"] = "ConfirmPassword",
        ["autocomplete"] = "new-password"
    };

    private readonly Dictionary<string, object?> _oldPasswordAttributes = new()
    {
        ["name"] = "OldPassword",
        ["autocomplete"] = "current-password"
    };
}

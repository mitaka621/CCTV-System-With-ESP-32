@page "/replay"
@rendermode InteractiveServer
@using CamPortal.Contracts.Constants
@using CamPortal.Contracts.Dtos.VideoChunkDtos
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize(Roles = $"{Roles.Admin},{Roles.User}")]

@inject IJSRuntime _js
@inject IDialogService _dialogService
@inject IDeviceService _cameraService
@inject IVideoReplayService _videoReplayService
@inject IUserTimeZoneService _userTimeZoneService

<PageTitle>Replay - BlazorCam Portal</PageTitle>

<MudText Typo="Typo.h3" Class="mb-4" Color="Color.Primary">
    <MudIcon Icon="@Icons.Material.Filled.VideoLibrary" Class="mr-3 icon-to-hide-on-mobile" />
    Video Replay & Events
</MudText>

<MudPaper Elevation="4" Class="pa-6 mb-6" Style="border-radius: 20px;">
    <MudGrid>
        <MudItem xs="12" md="6" lg="3">
            <MudDatePicker Label="From Date"
                @ref="_startDatePicker"
                MaxDate="DateTime.Now.Date"          
                DateChanged="OnFilterDateRangeChange"
                Class="mb-2" />
            <MudTimePicker Label="From Time"
                @bind-Time="_selectedStartTime"
                Class="mb-3" />
        </MudItem>
        <MudItem xs="12" md="6" lg="3">
            <MudDatePicker Label="To Date"
                @ref="_endDatePicker"
                MaxDate="DateTime.Now.Date"
                DateChanged="OnFilterDateRangeChange"
                Class="mb-2" />
            <MudTimePicker Label="To Time"
                @bind-Time="_selectedEndTime"
                Class="mb-3" />
        </MudItem>
        <MudItem xs="12" md="6" lg="3">
            <MudSelect T="NameAndIdWithStatusModel" Label="Camera Filter"
                Class="mb-3"
                MultiSelection="true"
                ToStringFunc="@((x)=>x.Name)"
                @bind-SelectedValues="_selectedCameraIds">
                @foreach (var camera in _allCamerasNameAndId)
                {
                    <MudSelectItem Value="@camera">@($"{(string.IsNullOrEmpty(camera.Name) ? camera.Id : camera.Name)} - ({camera.PairStatus})")</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="6" lg="3">
            <MudSelect T="CameraEvents" Label="Event Type Filter"
                @bind-SelectedValues="_selectedEventTypes"
                Class="mb-3"
                MultiSelection="true">
                @foreach (var item in Enum.GetValues<CameraEvents>())
                {
                    <MudSelectItem Value="@item">
                        @MiscUtilities.GetDisplayNameAttributeValue(item)
                    </MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudText Color="Color.Error" Class="ml-6">@_error</MudText>
        <MudItem xs="12">
            <MudStack Row="true" Justify="Justify.SpaceBetween">
                <MudStack Row="true">
                    <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="() => AutoApplyFilters(10)" Disabled="_isFiltering">
                        10 Minutes Ago
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="() => AutoApplyFilters(30)" Disabled="_isFiltering">
                        30 Minutes Ago
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="() => AutoApplyFilters(60)" Disabled="_isFiltering">
                        1 hour Ago
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="() => AutoApplyFilters(60*5)" Disabled="_isFiltering">
                        5 hours Ago
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="() => AutoApplyFilters(60*10)" Disabled="_isFiltering">
                        10 hours Ago
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="() => AutoApplyFilters(60*24)" Disabled="_isFiltering">
                        1 day Ago
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="() => AutoApplyFilters(60*24*2)" Disabled="_isFiltering">
                        2 days Ago
                    </MudButton>
                </MudStack>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="FilterCameras" Disabled="_isFiltering">
                    @if (_isFiltering)
                    {
                        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                        <MudText Class="ms-2">Processing</MudText>
                    }
                    else
                    {
                        <MudText>Apply Filters</MudText>
                    }
                </MudButton>
            </MudStack> 
        </MudItem>
    </MudGrid>
</MudPaper>
@if (_currentCameras.Count == 0)
{
    <MudPaper Elevation="2" Class="pa-8 text-center">
        <MudIcon Icon="@Icons.Material.Outlined.VideoLibrary" Size="Size.Large" Color="Color.Secondary" Class="mb-4" />
        <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mb-2">No Cameras Found</MudText>
        <MudText Typo="Typo.body1" Color="Color.Secondary">
            Adjust your filters to see available cameras and recordings
        </MudText>
    </MudPaper>
}
else
{
    <MudStack Spacing="4">
        @foreach (var camera in _currentCameras)
        {
            <MudCard Elevation="8" 
                Class="camera-timeline-card">
                <MudCardContent Class="pa-4">
                    <MudGrid AlignItems="Center">
                        <MudItem xs="12" md="5" lg="4">
                            <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="height:100%">
                                <div class="video-container" @onclick="() => OpenFullScreen(camera.Id)">
                                    <!-- player -->
                                    <video id="video-@camera.Id"></video>
                                    <div class="camera-info-overlay">
                                        <MudText Typo="Typo.subtitle2" Color="Color.Primary">@camera.Name</MudText>
                                    </div>
                                    <div class="camera-overlay">
                                        <MudIcon Icon="@Icons.Material.Filled.Fullscreen"
                                                 Color="Color.Primary"
                                                 Size="Size.Large" />
                                    </div>
                                </div>
                            </MudStack>                        
                        </MudItem>       
                        <MudItem xs="12" md="7" lg="8">
                            <div class="timeline-section">
                                <div class="timeline-header mb-3">
                                    <MudText Typo="Typo.subtitle1" Color="Color.Primary">
                                        <MudIcon Icon="@Icons.Material.Filled.Timeline" Size="Size.Small" Class="mr-2" />
                                        Event Timeline - @camera.Name
                                    </MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @GetCombinedStartDateTime()?.ToString("MMM dd, HH:mm") to @GetCombinedEndDateTime()?.ToString("MMM dd, HH:mm")
                                    </MudText>
                                </div>
                                <MudStack Justify="Justify.Center" Style="height:80%">
                                    <div class="timeline-container">
                                        <div class="timeline-track">
                                            <!-- time markers-->
                                            @{
                                                var playlist = _hLSPlaylists.FirstOrDefault(p => p.CameraId == camera.Id);
                                                var incrementMinutes = Math.Max(1, _totalTimelineDurationInMinutes / _maxNumberOfTimeMarkersPerCamera);
                                                var lastMarkerMinute = _totalTimelineDurationInMinutes / incrementMinutes * incrementMinutes;
                                                var timelineMaxWidth = _totalTimelineDurationInMinutes > 0 ? (double)lastMarkerMinute / _totalTimelineDurationInMinutes * 100 : 100;
                                            }
                                            <div style="display:flex; position:absolute; justify-content:space-between; width:@timelineMaxWidth%">
                                                @if (_totalTimelineDurationInMinutes > 0)
                                                {
                                                    @for (int minute = 0; minute <= _totalTimelineDurationInMinutes; minute += incrementMinutes)
                                                    {
                                                        var currentTime = GetCombinedStartDateTime()?.AddMinutes(minute);

                                                        <MudStack Class="@(minute != 0 && minute + incrementMinutes <= _totalTimelineDurationInMinutes ? "hidden" : string.Empty)"
                                                                  Style="gap:0 !important; width: 5px;"
                                                                  AlignItems="AlignItems.Center"
                                                                  Spacing="0">

                                                            <div class="timeline-marker"></div>
                                                            <div class="marker-label" style="display:flex; flex-direction:column; align-items:center">
                                                                <div>@currentTime!.Value.ToString("HH:mm")</div>
                                                                <div>@currentTime!.Value.ToString("MMM d")</div>
                                                            </div>
                                                        </MudStack>
                                                    }
                                                }

                                            </div>
                                            <!-- events -->
                                            <div class="timeline-events">
                                                @if (playlist != null)
                                                {
                                                    var eventStart = GetCombinedStartDateTime();
                                                    var eventEnd = GetCombinedEndDateTime();

                                                    if (eventStart == null || eventEnd == null)
                                                    {
                                                        return;
                                                    }

                                                    var totalTimelineMinutes = (eventEnd.Value - eventStart.Value).TotalMinutes;

                                                    var eventProperties = playlist.GetType()
                                                        .GetProperties()
                                                        .Where(p =>
                                                            p.PropertyType.IsGenericType &&
                                                            p.PropertyType.GetGenericTypeDefinition() == typeof(List<>) &&
                                                            p.PropertyType.GetGenericArguments()[0] == typeof(VideoChunkDateTimeEventDto));

                                                    foreach (var eventProperty in eventProperties)
                                                    {
                                                        var events = (List<VideoChunkDateTimeEventDto>)eventProperty.GetValue(playlist)!;

                                                        if (events.Count < 100)
                                                        {
                                                            foreach (var eventItem in events)
                                                            {
                                                                var localEventStart = _userTimeZoneService.ToLocal(eventItem.EventStartTime);
                                                                var localEventEnd = _userTimeZoneService.ToLocal(eventItem.EventEndTime);

                                                                var eventStartOffset = (localEventStart - eventStart.Value).TotalMinutes;
                                                                var eventDuration = (localEventEnd - localEventStart).TotalMinutes;

                                                                var leftPos = Math.Clamp(eventStartOffset / totalTimelineMinutes * 100, 0, 100);
                                                                var widthPercent = Math.Clamp(eventDuration / totalTimelineMinutes * 100, 0, 100 - leftPos);

                                                                <div class="timeline-event @eventProperty.Name"
                                                                     style="left: @(leftPos.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))%;
                                                                    width: @(widthPercent.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))%;"
                                                                     title="Available: @localEventStart.ToString("HH:mm:ss") - @localEventEnd.ToString("HH:mm:ss")">
                                                                </div>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            List<VideoChunkDateTimeEventDto> combinedEvents = new();

                                                            var firstEvent = events.First();

                                                            var previousChunk = new VideoChunkDateTimeEventDto()
                                                            {
                                                                EventStartTime = _userTimeZoneService.ToLocal(MiscUtilities.FloorToSecond(firstEvent.EventStartTime)),
                                                                EventEndTime = _userTimeZoneService.ToLocal(MiscUtilities.FloorToSecond(firstEvent.EventEndTime))
                                                            };

                                                            combinedEvents.Add(previousChunk);

                                                            foreach (var eventItem in events.Skip(1))
                                                            {
                                                                var localEventStart = _userTimeZoneService.ToLocal(MiscUtilities.FloorToSecond(eventItem.EventStartTime));
                                                                var localEventEnd = _userTimeZoneService.ToLocal(MiscUtilities.FloorToSecond(eventItem.EventEndTime));

                                                                if (previousChunk.EventEndTime == localEventStart || previousChunk.EventEndTime == localEventStart.AddSeconds(-1))
                                                                {
                                                                    previousChunk.EventEndTime = localEventEnd;

                                                                    continue;
                                                                }

                                                                previousChunk = new VideoChunkDateTimeEventDto()
                                                                {
                                                                    EventStartTime = localEventStart,
                                                                    EventEndTime = localEventEnd
                                                                };

                                                                combinedEvents.Add(previousChunk);
                                                            }

                                                            foreach (var combinedEvent in combinedEvents)
                                                            {
                                                                var eventStartOffset = (combinedEvent.EventStartTime - eventStart.Value).TotalMinutes;
                                                                var eventDuration = (combinedEvent.EventEndTime - combinedEvent.EventStartTime).TotalMinutes;

                                                                var leftPos = Math.Clamp(eventStartOffset / totalTimelineMinutes * 100, 0, 100);
                                                                var widthPercent = Math.Clamp(eventDuration / totalTimelineMinutes * 100, 0, 100 - leftPos);

                                                                <div class="timeline-event @eventProperty.Name"
                                                                     style="left: @(leftPos.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))%;
                                                                    width: @(widthPercent.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))%;"
                                                                     title="Available: @combinedEvent.EventStartTime.ToString("HH:mm:ss") - @combinedEvent.EventEndTime.ToString("HH:mm:ss")">
                                                                </div>
                                                            }
                                                        }
                                                    }
                                                }
                                            </div>
                                            <!--Camera timeline cursor -->
                                            <input id="timeline-cursor-@camera.Id"
                                                   type="range"
                                                   min="0"
                                                   max="100"
                                                   step="0.01"
                                                   value="0"
                                                   class="timeline-range-cursor" />
                                        </div>
                                        <div class="timeline-controls mt-2">
                                            <div class="d-flex justify-space-between align-center">
                                                <MudStack Row="true">
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                        Current Time: <span id="current-time-@camera.Id">@GetCombinedStartDateTime()?.ToString("HH:mm:ss")</span>
                                                    </MudText>
                                                    <div class="timeline-sync-controls">
                                                        <input id="camera-sync-enabled-@camera.Id" type="checkbox" checked />
                                                        <label for="camera-sync-enabled-@camera.Id" class="timeline-sync-label">Sync With Other Cameras</label>
                                                    </div>
                                                </MudStack>
                                                <MudButton StartIcon="@Icons.Material.Filled.Download"
                                                           Color="Color.Primary"
                                                           Size="Size.Small"
                                                           Variant="Variant.Filled">
                                                    Export
                                                </MudButton>
                                            </div>
                                        </div>
                                    </div>
                                </MudStack>
                            </div>
                        </MudItem>
                    </MudGrid>
                </MudCardContent>
            </MudCard>
        }
    </MudStack>
}

<script src="@Assets["/js/Libraries/hls.js"]"></script>
<script src="@Assets["/js/hlsPlayback.js"]"></script>
<script src="@Assets["/js/timelineController.js"]"></script>

@code {
    private const int _maxNumberOfTimeMarkersPerCamera=10;

    private List<NameAndIdWithStatusModel> _allCamerasNameAndId = new();
    private List<CameraDisplayModel> _currentCameras = new();
    private IEnumerable<NameAndIdWithStatusModel> _selectedCameraIds = new List<NameAndIdWithStatusModel>();
    private IEnumerable<CameraEvents> _selectedEventTypes = Enum.GetValues<CameraEvents>();
    private DateTime? _selectedStartDate=DateTime.Now.Date;
    private DateTime? _selectedEndDate = DateTime.Now.Date;
    private TimeSpan? _selectedStartTime;
    private TimeSpan? _selectedEndTime;
    private TimeSpan? _updatedNewStartTime;
    private TimeSpan? _updatedNewEndTime;
    private List<HLSPlaylistDto> _hLSPlaylists = new();
    private bool _isFiltering = false;
    private MudDatePicker? _startDatePicker;
    private MudDatePicker? _endDatePicker;
    private string _error = string.Empty;
    private int _totalTimelineDurationInMinutes=0;

    protected override async Task OnInitializedAsync()
    {
        _selectedStartTime = new TimeSpan();
        _selectedEndTime = new TimeSpan(DateTime.Now.Hour, DateTime.Now.Minute, 0);

        _allCamerasNameAndId = await _cameraService.GetAllCameraNameAndIdAsync();

        if (_startDatePicker!=null && _endDatePicker!=null)
        {
            await _startDatePicker.GoToDate(_userTimeZoneService.ToLocal(DateTime.UtcNow));
            await _endDatePicker.GoToDate(_userTimeZoneService.ToLocal(DateTime.UtcNow));
        }
    }

    private void OnFilterDateRangeChange()
    {
        if (_startDatePicker == null || _endDatePicker == null || _startDatePicker.Date == null || _endDatePicker.Date == null)
        {
            return;
        }

        if (_startDatePicker.Date > _endDatePicker.Date)
        {
            _endDatePicker.GoToDate(_startDatePicker.Date.Value);
        }

        if (_endDatePicker.Date < _startDatePicker.Date)
        {
            _startDatePicker.GoToDate(_endDatePicker.Date.Value);
        }

        _selectedStartDate = _startDatePicker.Date;
        _selectedEndDate=_endDatePicker.Date;
    }

    private async Task FilterCameras()
    {
        try
        {
            _updatedNewStartTime=_selectedStartTime;
            _updatedNewEndTime=_selectedEndTime;

            var startDateTime = GetCombinedStartDateTime();
            var endDateTime = GetCombinedEndDateTime();

            if (startDateTime == null || endDateTime == null || _selectedCameraIds.Count() == 0)
            {
                _currentCameras = new();
                return;
            }

            if (endDateTime<startDateTime)
            {
                _error = "The start date and time cannot be before the end date and time";

                return;
            }

            _error = string.Empty;

            _isFiltering = true;

            var startDateTimeUtc = _userTimeZoneService.ToUtc(startDateTime.Value);
            var endDateTimeUtc = _userTimeZoneService.ToUtc(endDateTime.Value);

            var selectedCameraIdsList = _selectedCameraIds.Select(x=>x.Id).Distinct().ToList();

            _currentCameras = await _cameraService.GetAllCamerasAsync(selectedCameraIdsList);

            _hLSPlaylists = await _videoReplayService
                .GenerateHLSPlaylistsAsync(selectedCameraIdsList, startDateTimeUtc, endDateTimeUtc);

            var missingChunks = _hLSPlaylists.SelectMany(x => x.MissingVideoChunkEvents.Select(x=>x.TotalDuration))
                .Distinct();

            await _videoReplayService.GeneratePlaceholderChunksForMissingOnesAsync(missingChunks);

            _totalTimelineDurationInMinutes = GetTimelineDurationInMinutes();
        }
        finally
        {
            _isFiltering = false;
            await InvokeAsync(StateHasChanged);

            await Task.Delay(50);
            await BeginHLSStream();
        }
    }

    private async Task BeginHLSStream()
    {
        if (!_hLSPlaylists.Any())
        {
            return;
        }

        var start = GetCombinedStartDateTime();
        var end = GetCombinedEndDateTime();
        var durationSeconds = start != null && end != null
            ? (end.Value - start.Value).TotalSeconds
            : 0;
        var startIso = start?.ToString("o") ?? string.Empty;

        await _js.InvokeVoidAsync("resetTimelines");

        foreach (var cam in _hLSPlaylists)
        {
            await _js.InvokeVoidAsync("initHlsStream", $"video-{cam.CameraId}", cam.HLSPlaylistString);
            await _js.InvokeVoidAsync("initTimelineForCamera", cam.CameraId.ToString(), startIso, durationSeconds);
        }
    }

    private async Task OpenFullScreen(Guid cameraId)
    {
        await _js.InvokeVoidAsync("openFullScreen", $"video-{cameraId}");
    }

    private DateTime? GetCombinedStartDateTime()
    {
        if (_selectedStartDate.HasValue && _updatedNewStartTime.HasValue)
            return _selectedStartDate.Value.Date.Add(_updatedNewStartTime.Value);
        return null;
    }

    private DateTime? GetCombinedEndDateTime()
    {
        if (_selectedEndDate.HasValue && _updatedNewEndTime.HasValue)
            return _selectedEndDate.Value.Date.Add(_updatedNewEndTime.Value);
        return null;
    }

    private int GetTimelineDurationInMinutes()
    {
        var start = GetCombinedStartDateTime();
        var end = GetCombinedEndDateTime();

        if (start != null && end != null)
        {
            return (int)(end.Value - start.Value).TotalMinutes;
        }

        return 0;
    }

    private void AutoApplyFilters(int minutesAgo)
    {
        if (_startDatePicker == null || _endDatePicker == null || _selectedStartTime==null)
        {
            return;
        }

        var currentTime=_userTimeZoneService.ToLocal(DateTime.UtcNow);

        currentTime=currentTime.AddMinutes(-minutesAgo);

        _startDatePicker.GoToDate(currentTime.Date);

        _selectedStartTime = new TimeSpan(currentTime.Hour, currentTime.Minute, currentTime.Second);

       StateHasChanged();
    }
}

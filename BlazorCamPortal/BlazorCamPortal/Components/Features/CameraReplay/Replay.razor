@page "/replay"
@rendermode InteractiveServer
@using CamPortal.Contracts.Constants
@using CamPortal.Contracts.Dtos.VideoChunkDtos
@using Microsoft.AspNetCore.Authorization
@using Microsoft.JSInterop

@attribute [Authorize(Roles = $"{Roles.Admin},{Roles.User}")]

@inject IJSRuntime _js
@inject IDialogService _dialogService
@inject IDeviceService _cameraService
@inject IVideoReplayService _videoReplayService

<PageTitle>Replay - BlazorCam Portal</PageTitle>

<MudText Typo="Typo.h3" Class="mb-4" Color="Color.Primary">
    <MudIcon Icon="@Icons.Material.Filled.VideoLibrary" Class="mr-3 icon-to-hide-on-mobile" />
    Video Replay & Events
</MudText>

<MudPaper Elevation="4" Class="pa-6 mb-6">
    <MudGrid>
        <MudItem xs="12" md="6" lg="3">
            <MudDatePicker Label="From Date"
                @bind-Date="selectedStartDateTime"
                MinDate="minDateTime.Date"
                MaxDate="selectedEndDateTime?.Date ?? maxDateTime.Date"
                Class="mb-2" />
            <MudTimePicker Label="From Time"
                @bind-Time="selectedStartTime"
                Class="mb-3" />
        </MudItem>
        <MudItem xs="12" md="6" lg="3">
            <MudDatePicker Label="To Date"
                @bind-Date="selectedEndDateTime"
                MinDate="selectedStartDateTime?.Date ?? minDateTime.Date"
                MaxDate="maxDateTime.Date"
                Class="mb-2" />
            <MudTimePicker Label="To Time"
                @bind-Time="selectedEndTime"
                Class="mb-3" />
        </MudItem>
        <MudItem xs="12" md="6" lg="3">
            <MudSelect T="Guid" Label="Camera Filter"
                Class="mb-3"
                MultiSelection="true"
                @bind-SelectedValues="selectedCameraIds">
                @foreach (var camera in allCamerasNameAndId)
                {
                    <MudSelectItem Value="@camera.Id">@($"{camera.Name} - ({camera.Status})")</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="6" lg="3">
            <MudSelect T="int" Label="Event Type Filter"
                SelectedValues="selectedEventTypes"
                Class="mb-3"
                MultiSelection="true">
                @foreach (var item in Enum.GetValues<CameraEvents>())
                {
                    <MudSelectItem Value="@((int)item)">
                        @MiscUtilities.GetDisplayNameAttributeValue(item)
                    </MudSelectItem>
                }
            </MudSelect>
        </MudItem>

        <MudItem xs="12">
            @if (minDateTime != default && maxDateTime != default)
            {
                <MudAlert Severity="Severity.Info" Class="mb-3">
                    <MudText Typo="Typo.caption">
                        <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="mr-2" />
                        Available video range: <strong>@minDateTime.ToString("MMM dd, yyyy HH:mm")</strong> to <strong>@maxDateTime.ToString("MMM dd, yyyy HH:mm")</strong>
                    </MudText>
                </MudAlert>
            }
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="FilterCameras" Disabled="isFiltering" Loading="isFiltering">
                Apply Filters
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>


<!-- Cameras Grid -->
@if (currentCameras.Count == 0)
{
    <MudPaper Elevation="2" Class="pa-8 text-center">
        <MudIcon Icon="@Icons.Material.Outlined.VideoLibrary" Size="Size.Large" Color="Color.Secondary" Class="mb-4" />
        <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mb-2">No Cameras Found</MudText>
        <MudText Typo="Typo.body1" Color="Color.Secondary">
            Adjust your filters to see available cameras and recordings
        </MudText>
    </MudPaper>
}
else
{
    <MudStack Spacing="4">
        @foreach (var camera in currentCameras)
        {
            <MudCard Elevation="8" 
                Class="camera-timeline-card">
                <MudCardContent Class="pa-4">
                    <MudGrid AlignItems="Center">
                        <!-- Left Side: Camera Preview and Info -->
                        <MudItem xs="12" md="5" lg="4">
                            <div class="video-container">
                                <video id="video-@camera.Id"></video>
                                <div class="camera-info-overlay">
                                    <MudText Typo="Typo.subtitle2" Color="Color.Primary">@camera.Name</MudText>
                                </div>
                            </div>
                        </MudItem>
                        
                        <!-- Right Side: Timeline and Events -->
                        <MudItem xs="12" md="7" lg="8">
                            <div class="timeline-section">
                                <!-- Timeline Header -->
                                <div class="timeline-header mb-3">
                                    <MudText Typo="Typo.subtitle1" Color="Color.Primary">
                                        <MudIcon Icon="@Icons.Material.Filled.Timeline" Size="Size.Small" Class="mr-2" />
                                        Event Timeline - @camera.Name
                                    </MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @GetCombinedStartDateTime()?.ToString("MMM dd, HH:mm") to @GetCombinedEndDateTime()?.ToString("MMM dd, HH:mm")
                                    </MudText>
                                </div>

                                <!-- Interactive Timeline Container -->
                                <div class="timeline-container" id="timeline-@camera.Id">
                                    <!-- Timeline Background -->
                                    <div class="timeline-track">
                                        <!-- Time Markers -->
                                        <div class="timeline-markers">
                                            @{
                                                var timelineDuration = GetTimelineDurationInMinutes();
                                                var playlist = hLSPlaylists.FirstOrDefault(p => p.CameraId == camera.Id);
                                            }

                                            @if (timelineDuration > 0)
                                            {
                                                @for (int minute = 0; minute <= timelineDuration; minute++)
                                                {
                                                    var leftPosition = (double)minute / timelineDuration * 100;
                                                    var isRoundNumber = minute % 10 == 0 && minute > 0;
                                                    var showLabel = minute % 5 == 0; // Show label at 0 and every 5 minutes
                                                    
                                                    <div class="timeline-marker @(isRoundNumber ? "round-marker" : (showLabel ? "label-marker" : "minute-marker"))"
                                                         style="left: @(leftPosition.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))%;"
                                                         data-minute="@minute">
                                                        @if (showLabel)
                                                        {
                                                            <div class="marker-label" 
                                                                 style="position: absolute; bottom: -35px; left: 50%; transform: translateX(-50%); z-index: 20;">
                                                                @GetCombinedStartDateTime()?.AddMinutes(minute).ToString("HH:mm")
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                            }
                                        </div>

                                        <!-- Events Layer -->
                                        <div class="timeline-events">
                                            @if (playlist != null)
                                            {
                                                <!-- Available Video Chunk Events (Green) -->
                                                @foreach (var eventItem in playlist.AvailableVideoChunkEvents)
                                                {
                                                    var eventStart = GetCombinedStartDateTime();
                                                    var eventEnd = GetCombinedEndDateTime();
                                                    if (eventStart != null && eventEnd != null)
                                                    {
                                                        var totalDuration = (eventEnd.Value - eventStart.Value).TotalMinutes;
                                                        var eventStartOffset = (eventItem.EventStartTime - eventStart.Value).TotalMinutes;
                                                        var eventDuration = eventItem.Duration / 60.0; // Convert to minutes
                                                        
                                                        var leftPos = (eventStartOffset / totalDuration) * 100;
                                                        var widthPercent = (eventDuration / totalDuration) * 100;
                                                        
                                                        <div class="timeline-event available-event"
                                                             style="left: @(leftPos.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))%; 
                                                                    width: @(Math.Max(0.5, widthPercent).ToString("F2", System.Globalization.CultureInfo.InvariantCulture))%;"
                                                             title="Available: @eventItem.EventStartTime.ToString("HH:mm:ss") - @eventItem.EventEndTime.ToString("HH:mm:ss")">
                                                        </div>
                                                    }
                                                }

                                                <!-- Missing Video Chunk Events (Red) -->
                                                @foreach (var eventItem in playlist.MissingVideoChunkEvents)
                                                {
                                                    var eventStart = GetCombinedStartDateTime();
                                                    var eventEnd = GetCombinedEndDateTime();
                                                    if (eventStart != null && eventEnd != null)
                                                    {
                                                        var totalDuration = (eventEnd.Value - eventStart.Value).TotalMinutes;
                                                        var eventStartOffset = (eventItem.EventStartTime - eventStart.Value).TotalMinutes;
                                                        var eventDuration = eventItem.Duration / 60.0; // Convert to minutes
                                                        
                                                        var leftPos = (eventStartOffset / totalDuration) * 100;
                                                        var widthPercent = (eventDuration / totalDuration) * 100;
                                                        
                                                        <div class="timeline-event missing-event"
                                                             style="left: @(leftPos.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))%; 
                                                                    width: @(Math.Max(0.5, widthPercent).ToString("F2", System.Globalization.CultureInfo.InvariantCulture))%;"
                                                             title="Missing: @eventItem.EventStartTime.ToString("HH:mm:ss") - @eventItem.EventEndTime.ToString("HH:mm:ss")">
                                                        </div>
                                                    }
                                                }
                                            }
                                        </div>

                                        <!-- Interactive Cursor -->
                                        <div class="timeline-cursor" 
                                             id="cursor-@camera.Id"
                                             @onmousedown="@((e) => StartDrag(camera.Id, e))"
                                             style="left: 0%;">
                                            <div class="cursor-line"></div>
                                            <div class="cursor-handle"></div>
                                            <!-- DateTime Bubble -->
                                            <div class="cursor-bubble" id="bubble-@camera.Id" style="display: none;">
                                                <span id="bubble-text-@camera.Id"></span>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Timeline Controls -->
                                    <div class="timeline-controls mt-2">
                                        <div class="d-flex justify-space-between align-center">
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                Current Time: <span id="current-time-@camera.Id">@GetCombinedStartDateTime()?.ToString("HH:mm:ss")</span>
                                            </MudText>
                                            <div class="timeline-sync-controls">
                                                <MudCheckBox T="bool" @bind-Value="syncAllTimelines" Label="Sync All Cameras" Color="Color.Primary" Size="Size.Small" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </MudItem>
                    </MudGrid>
                </MudCardContent>
            </MudCard>
        }
    </MudStack>
}

<script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
<script src="@Assets["/js/hlsPlayback.js"]"></script>
<script src="@Assets["/js/timelineController.js"]"></script>

@code {
    List<NameAndIdWithStatusModel> allCamerasNameAndId = new();
    List<CameraDisplayModel> currentCameras = new();
    IEnumerable<Guid> selectedCameraIds = new HashSet<Guid>();
    HashSet<int> selectedEventTypes = Enum.GetValues<CameraEvents>().Cast<int>().ToHashSet();
    DateTime? selectedStartDateTime;
    DateTime? selectedEndDateTime;
    TimeSpan? selectedStartTime;
    TimeSpan? selectedEndTime;

    DateTime minDateTime;
    DateTime maxDateTime;

    List<HLSPlaylistDto> hLSPlaylists = new();
    bool isFiltering = false;
    bool syncAllTimelines = true;
    private Guid currentDraggingCamera = Guid.Empty;

    protected override async Task OnInitializedAsync()
    {
        (minDateTime, maxDateTime) = await _videoReplayService.GetMinAndMaxDateTimeOfAvailableVideoChunksAsync();
        allCamerasNameAndId = await _cameraService.GetAllCameraNameAndIdAsync();

        var now = DateTime.UtcNow;
        var defaultEnd = now <= maxDateTime ? now : maxDateTime;
        var defaultStart = defaultEnd.AddMinutes(-30);
        if (defaultStart < minDateTime)
        {
            defaultStart = minDateTime;
        }
        if (defaultStart >= defaultEnd)
        {
            defaultStart = defaultEnd.AddMinutes(-1);
            if (defaultStart < minDateTime)
            {
                defaultStart = minDateTime;
            }
        }

        selectedStartDateTime = defaultStart.Date;
        selectedEndDateTime = defaultEnd.Date;
        selectedStartTime = defaultStart.TimeOfDay;
        selectedEndTime = defaultEnd.TimeOfDay;
    }

    private async Task FilterCameras()
    {
        try
        {
            var startDateTime = GetCombinedStartDateTime();
            var endDateTime = GetCombinedEndDateTime();

            if (startDateTime == null || endDateTime == null || selectedCameraIds.Count() == 0)
            {
                currentCameras = new();
                return;
            }

            if (startDateTime < minDateTime || endDateTime > maxDateTime || startDateTime >= endDateTime)
            {
                var message = $"Invalid date/time selection. Available range: {minDateTime:MMM dd, yyyy HH:mm} to {maxDateTime:MMM dd, yyyy HH:mm}";
                await _dialogService.ShowMessageBox("Invalid Date Range", message, "OK");
                return;
            }

            isFiltering = true;

            var selectedCameraIdsList = selectedCameraIds.ToList();

            currentCameras = await _cameraService.GetAllCamerasAsync(selectedCameraIdsList);

            hLSPlaylists = await _videoReplayService
                .GenerateHLSPlaylistsAsync(selectedCameraIdsList, startDateTime.Value, endDateTime.Value);

            var missingChunks = hLSPlaylists.SelectMany(x => x.MissingVideoChunkEvents)
                .DistinctBy(x=>x.Duration);

            List<Task> generateMissingChunksTasks = new();

            foreach (var missingEvent in missingChunks)
            {
                if (missingEvent.Duration <= 0)
                {
                    continue;
                }

                generateMissingChunksTasks.Add(_videoReplayService.GeneratePlaceholderChunksForMissingOnesAsync(missingEvent.Duration));
            }

            await Task.WhenAll(generateMissingChunksTasks);
        }
        finally
        {
            isFiltering = false;
            StateHasChanged();

            await Task.Delay(50);
            await BeginHLSStream();
        }

    }

    private async Task BeginHLSStream()
    {
        if (hLSPlaylists.Any())
        {
            foreach (var cam in hLSPlaylists)
            {
                await _js.InvokeVoidAsync("initHlsStream", $"video-{cam.CameraId}", cam.HLSPlaylistString);
                
                // Initialize timeline for this camera
                await _js.InvokeVoidAsync("initTimelineForCamera", cam.CameraId.ToString());
            }
            
            // Set up Blazor component reference for JavaScript callbacks
            var objRef = DotNetObjectReference.Create(this);
            await _js.InvokeVoidAsync("setBlazorComponentInstance", objRef);
        }
    }

    private DateTime? GetCombinedStartDateTime()
    {
        if (selectedStartDateTime.HasValue && selectedStartTime.HasValue)
            return selectedStartDateTime.Value.Date.Add(selectedStartTime.Value);
        return null;
    }

    private DateTime? GetCombinedEndDateTime()
    {
        if (selectedEndDateTime.HasValue && selectedEndTime.HasValue)
            return selectedEndDateTime.Value.Date.Add(selectedEndTime.Value);
        return null;
    }

    private double GetTimelineDurationInMinutes()
    {
        var start = GetCombinedStartDateTime();
        var end = GetCombinedEndDateTime();
        
        if (start != null && end != null)
        {
            return (end.Value - start.Value).TotalMinutes;
        }
        
        return 0;
    }

    private async Task StartDrag(Guid cameraId, MouseEventArgs e)
    {
        currentDraggingCamera = cameraId;
        
        // Show the bubble immediately when dragging starts
        await _js.InvokeVoidAsync("showTimelineBubble", cameraId.ToString());
        
        // Add global mouse events
        await _js.InvokeVoidAsync("addGlobalTimelineEvents", cameraId.ToString(), syncAllTimelines);
    }

    [JSInvokable]
    public async Task OnTimelinePositionChanged(string cameraId, double percentage)
    {
        var start = GetCombinedStartDateTime();
        var end = GetCombinedEndDateTime();
        
        if (start != null && end != null && Guid.TryParse(cameraId, out var camGuid))
        {
            var totalDuration = (end.Value - start.Value).TotalSeconds;
            var targetTime = start.Value.AddSeconds(totalDuration * (percentage / 100));
            
            // Calculate relative seconds from start for video seeking
            var relativeSeconds = totalDuration * (percentage / 100);
            
            // Update the current time display
            await _js.InvokeVoidAsync("updateCurrentTimeDisplay", cameraId, targetTime.ToString("HH:mm:ss"));
            
            // Update the datetime bubble
            await _js.InvokeVoidAsync("updateTimelineBubble", cameraId, targetTime.ToString("MMM dd, HH:mm:ss"));
            
            // Sync video player to this time using relative seconds
            await _js.InvokeVoidAsync("seekVideoToRelativeTime", $"video-{cameraId}", relativeSeconds);
            
            // If sync is enabled, update all other timelines
            if (syncAllTimelines)
            {
                foreach (var camera in currentCameras)
                {
                    if (camera.Id.ToString() != cameraId)
                    {
                        await _js.InvokeVoidAsync("updateTimelineCursor", camera.Id.ToString(), percentage);
                        await _js.InvokeVoidAsync("updateCurrentTimeDisplay", camera.Id.ToString(), targetTime.ToString("HH:mm:ss"));
                        await _js.InvokeVoidAsync("seekVideoToRelativeTime", $"video-{camera.Id}", relativeSeconds);
                    }
                }
            }
        }
    }

    [JSInvokable]
    public async Task OnTimelineDragEnd(string cameraId)
    {
        currentDraggingCamera = Guid.Empty;
        
        // Hide the bubble after drag ends
        await _js.InvokeVoidAsync("hideTimelineBubble", cameraId);
    }

    [JSInvokable]
    public string GetFormattedTimeForPercentage(string cameraId, double percentage)
    {
        var start = GetCombinedStartDateTime();
        var end = GetCombinedEndDateTime();
        
        if (start != null && end != null)
        {
            var totalDuration = (end.Value - start.Value).TotalSeconds;
            var targetTime = start.Value.AddSeconds(totalDuration * (percentage / 100));
            return targetTime.ToString("HH:mm:ss");
        }
        
        return "00:00:00";
    }
}

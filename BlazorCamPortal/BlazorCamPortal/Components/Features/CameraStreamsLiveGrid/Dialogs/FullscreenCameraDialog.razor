@using MudBlazor
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject IDialogService DialogService

<MudDialog>
    <DialogContent>
        <div class="fullscreen-camera">
            <div class="fullscreen-header">
                <div class="fullscreen-controls">
                    <MudIconButton Icon="@Icons.Material.Filled.Close" 
                                   Color="Color.Error" 
                                   Size="Size.Medium"
                                   Class="close-button"
                                   OnClick="CloseDialog" />
                </div>
            </div>
            
            <div class="fullscreen-video-container">
                <div class="fullscreen-loading">
                    <MudProgressCircular Indeterminate="true"
                                         Color="Color.Primary"
                                         Size="Size.Large" />
                    <span class="fullscreen-loading-text">Connecting to stream...</span>
                </div>
                <img id="@FullscreenElementId"
                     class="fullscreen-stream"
                     draggable="false" />
            </div>
         </div>
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter] 
    public IMudDialogInstance? MudDialog { get; set; }

    [Parameter] 
    public Guid CameraId { get; set; } = default!;

    private bool _hasRenderedInteractively;
    private string FullscreenElementId => $"fullscreen-{CameraId}";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _hasRenderedInteractively = true;
            await JS.InvokeVoidAsync("forceDialogFullscreen");
            await JS.InvokeVoidAsync("startCameraStream", FullscreenElementId, GetStreamUrl());
        }
    }

    private void CloseDialog()
    {
        MudDialog?.Close();
    }

    private string GetStreamUrl() => $"/api/cameras/{CameraId}/stream?isOriginalResolution=true";

    public async ValueTask DisposeAsync()
    {
        if (!_hasRenderedInteractively)
            return;

        try
        {
            await JS.InvokeVoidAsync("stopCameraStreamById", FullscreenElementId);
        }
        catch (JSDisconnectedException) { }
        catch (TaskCanceledException) { }
        catch (InvalidOperationException) { }
    }
}

@using CamPortal.Components.Features.DeviceConfig.Components

<MudDialog>
    <DialogContent>
        <ConfigureDeviceComponent CameraId="CameraId" ModelChanged="StateHasChanged" LoadExistingConfiguration="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close" Color="Color.Primary">Done</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    public IMudDialogInstance? MudDialog { get; set; }

    [Parameter, EditorRequired]
    public Guid CameraId { get; set; }

    private void Close()
    {
        MudDialog?.Close();
    }
}

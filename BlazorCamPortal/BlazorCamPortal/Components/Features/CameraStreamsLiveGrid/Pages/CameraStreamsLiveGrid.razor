@page "/"
@rendermode InteractiveServer
@using CamPortal.Components.Features.CameraStreamsLiveGrid.Components
@using CamPortal.Components.Features.CameraStreamsLiveGrid.Dialogs
@using CamPortal.Contracts.Constants
@using CamPortal.Contracts.Dtos.UserCameraLayoutDtos
@using CamPortal.Contracts.Enums
@using CamPortal.Core.Utilities
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using CamPortal.Contracts.Dtos.CameraConfigurationDtos

@attribute [Authorize(Roles = $"{Roles.Admin},{Roles.User}")]

@implements IAsyncDisposable
@inject IDeviceService _cameraService
@inject IUserCameraLayoutService _userCameraLayoutService
@inject IUserSettingsService _userSettingsService
@inject IDialogService _dialogService
@inject IJSRuntime _js

<PageTitle>Dashboard - BlazorCam Portal</PageTitle>

<PageLoader IsLoading="_isLoading" Message="Loading dashboard...">

<Dashboard></Dashboard>

<MudStack Row="true" Spacing="2" Class="mb-4 pt-4">
    <MudText Typo="Typo.h4" Color="Color.Secondary" Class="mb-0">
        <MudIcon Icon="@Icons.Material.Filled.GridView" Class="mr-2 icon-to-hide-on-mobile" />
        Live Camera Feeds
    </MudText>
    <MudTooltip Text="Camera grid settings">
        <MudIconButton Icon="@Icons.Material.Filled.Settings"
                       Color="Color.Secondary"
                       OnClick="OpenGridSettingsDialogAsync" />
    </MudTooltip>
</MudStack>

@if (!_cells.Any())
{
    <MudPaper Elevation="2" Class="pa-8 text-center">
        <MudIcon Icon="@Icons.Material.Outlined.VideocamOff" Size="Size.Large" Color="Color.Secondary" Class="mb-4" />
        <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mb-2">No Cameras Connected</MudText>
        <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-4">Get started by configuring your first camera</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Href="/camerasConfig">
            Configure Cameras
        </MudButton>
    </MudPaper>
}
else
{
        <MudDropContainer @key="_gridKey" T="CameraGridCellDto"
                      @ref="_dropContainer"
                      Items="_cells"
                      ItemsSelector="@((cell, zone) => cell.LocationAsString == zone)"
                      ItemsClassSelector="@((cell, zone) => _layoutMatrix[cell.Y][cell.X].LayoutType==CameraLayoutType.Vertical ? "board-item-tall" : string.Empty)"
                      CanDrop="@CanDrop"
                      ApplyDropClassesOnDragStarted="false"
                      CanDropClass="board-cell-can"
                      NoDropClass="board-cell-no"
                      ItemDropped="ItemUpdated">
        <ChildContent>
            <div class="camera-board" style="--cols:@_camerasPerRow">
                @for (int y = 0; y < _layoutMatrix.Count; y++)
                {
                    @for (int x = 0; x < _layoutMatrix[y].Length; x++)
                    {
                        <MudDropZone T="CameraGridCellDto"
                                     Identifier="@($"{y}_{x}")"
                                     ItemDraggingClass="camera-tile-dragging"
                                     Class="@(_layoutMatrix[y][x].LayoutType == CameraLayoutType.Reserved ? "board-cell board-cell-reserved" : "board-cell")" />
                    }
                }
            </div>
        </ChildContent>
        <ItemRenderer>
                <MudCard Elevation="6" Class="@(_layoutMatrix[context.Y][context.X].LayoutType == CameraLayoutType.Vertical ? "camera-card camera-card-tall" : "camera-card")">
                <MudCardHeader>
                    <CardHeaderContent>
                        <div class="d-flex align-center justify-space-between camera-drag-handle">
                            <div class="camera-info-container">
                                <MudTooltip Text="@GetCameraDisplayName(_layoutMatrix[context.Y][context.X].CameraInfo!)"
                                          Placement="Placement.Top"
                                          ShowOnFocus="false"
                                          ShowOnHover="true"
                                          Class="camera-name-tooltip">
                                    <MudText Typo="Typo.body1" Class="camera-name-text">
                                        <MudIcon Icon="@Icons.Material.Filled.DragIndicator" Size="Size.Small" Class="mr-2 camera-drag-indicator" />
                                        <span class="camera-name-span">@GetCameraDisplayName(_layoutMatrix[context.Y][context.X].CameraInfo!)</span>
                                    </MudText>
                                </MudTooltip>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    @_layoutMatrix[context.Y][context.X].CameraInfo!.Ipv4Address
                                </MudText>
                            </div>
                            <MudChip T="string" Color="Color.Success" Size="Size.Small" Icon="@Icons.Material.Filled.FiberManualRecord">
                                Live
                            </MudChip>
                        </div>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pa-0 camera-card-content">
                    <CameraStreamComponent CameraId="_layoutMatrix[context.Y][context.X].CameraInfo!.Id" Fill="true" StreamToken="_streamVersion" />
                </MudCardContent>
                <MudCardActions>
                    <MudSpacer />
                    <MudIconButton Icon="@Icons.Material.Filled.Settings" Color="Color.Default" Size="Size.Small" OnClick="() => OpenConfigDialog(_layoutMatrix[context.Y][context.X].CameraInfo!.Id)" />
                </MudCardActions>
            </MudCard>
        </ItemRenderer>
    </MudDropContainer>
}

</PageLoader>

    @code {
    private int _camerasPerRow;
    private MudDropContainer<CameraGridCellDto>? _dropContainer;
    private Guid _userId;
    private bool _hasRenderedInteractively;
    private bool _isLoading = true;
    private List<UserCameraLayoutItemDto[]> _layoutMatrix = new();
    private bool _boardSized;
    private int _gridKey = 0;
    private Guid _streamVersion = Guid.NewGuid();

    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    private IEnumerable<CameraGridCellDto> _cells=new List<CameraGridCellDto>();
    private HashSet<string> _reserved = new();
    private Dictionary<Guid, CameraAspectRatios> _aspectRatios = new();

    protected override async Task OnInitializedAsync()
    {
        await ResolveUserIdAsync();
        _camerasPerRow = await _userSettingsService.GetNumberOfCamerasPerRowAsync(_userId);
        await LoadCamerasAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _hasRenderedInteractively = true;
        }

        if (!_isLoading && !_boardSized && _cells.Any())
        {
            _boardSized = true;
            await _js.InvokeVoidAsync("initCameraDragHandles");
            await _js.InvokeVoidAsync("initCameraBoardSizing");
        }
    }

    private async Task ResolveUserIdAsync()
    {
        if (AuthStateTask is null)
        {
            return;
        }

        var authState = await AuthStateTask;
        _userId = AuthHelper.GetLoggedUserId(authState.User);
    }

    private async Task LoadCamerasAsync()
    {
        _isLoading = true;

        try
        {
            _layoutMatrix = await _userCameraLayoutService.GetLatestLayoutAsync(_userId);

            await _userCameraLayoutService.SaveNewLayoutAsync(_userId, _layoutMatrix);

            UpdateCells();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private bool CanDrop(CameraGridCellDto cell, string zone)
    {
        var zoneSplit=zone.Split("_");
        var targetY = int.Parse(zoneSplit[0]);
        var targetX = int.Parse(zoneSplit[1]);

        return _userCameraLayoutService.CanPlace(_layoutMatrix, cell, new CameraGridCellDto(){X = targetX, Y = targetY});
    }

    private async Task ItemUpdated(MudItemDropInfo<CameraGridCellDto> dropInfo)
    {
        if (dropInfo.Item==null)
        {
            return;
        }

        var zoneSplit = dropInfo.DropzoneIdentifier.Split("_");
        var targetY = int.Parse(zoneSplit[0]);
        var targetX = int.Parse(zoneSplit[1]);

        _layoutMatrix = await _userCameraLayoutService.SwapLayoutsAsync(_userId, _layoutMatrix, dropInfo.Item, new CameraGridCellDto { X = targetX, Y = targetY });

        UpdateCells();

        _dropContainer?.Refresh();
    }

    private string GetCameraDisplayName(CameraInfoWithConfigurationDto dto)
    {
        if (dto==null)
        {
            return string.Empty;
        }

        if (!string.IsNullOrEmpty(dto.Name))
            return dto.Name;

        return $"{dto.Id}";
    }

    private async Task OpenGridSettingsDialogAsync()
    {
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await _dialogService.ShowAsync<ConfigureNumberOfCamerasPerRowDialog>("Camera Grid Settings", options);

        try
        {
            var result = await dialog.Result;
        }
        catch (TaskCanceledException)
        {
            return;
        }

        await ReloadComponent();
    }

    private async Task OpenConfigDialog(Guid cameraId)
    {
        var parameters = new DialogParameters
        {
            ["CameraId"] = cameraId
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Large,
            FullWidth = true,
            Position = DialogPosition.TopCenter,
            BackdropClick = false,
            BackgroundClass = "blurry-background"
        };

        var dialog = await _dialogService.ShowAsync<ConfigureCameraDialog>(null, parameters, options);

        await dialog.Result;

        await ReloadComponent();
    }

    private async Task ReloadComponent()
    {
        _camerasPerRow = await _userSettingsService.GetNumberOfCamerasPerRowAsync(_userId);
        _boardSized = false;
        _dropContainer = null;
        _streamVersion = Guid.NewGuid();
        await LoadCamerasAsync();
        _gridKey++;
        await InvokeAsync(StateHasChanged);
    }

    private void UpdateCells()
    {
        _cells=_layoutMatrix.SelectMany(x => x)
            .Where(x => x.CameraInfo != null)
            .Where(x => x.LayoutType == CameraLayoutType.Horizontal || x.LayoutType == CameraLayoutType.Vertical)
            .Select(x => new CameraGridCellDto()
            {
                X = x.X,
                Y = x.Y
            });
    }

    public async ValueTask DisposeAsync()
    {
        if (!_hasRenderedInteractively)
            return;

        try
        {
            await _js.InvokeVoidAsync("stopCameraStreams", ".camera-stream");
        }
        catch (JSDisconnectedException) { }
        catch (TaskCanceledException) { }
        catch (InvalidOperationException) { }
    }
}

@using CamPortal.Components.Features.DeviceConfig.Components
@using CamPortal.Components.Shared
@inject IDeviceTypeService _deviceTypeService
@inject IDevicePreProvisionService _devicePreProvisionService
@inject IDialogService _dialogService
@inject ISnackbar _snackbar

<MudDialog>
    <DialogContent>
        <MudText Align="Align.Center" Typo="Typo.h4">Add Device</MudText>
        <MudTimeline 
            TimelineOrientation="TimelineOrientation.Horizontal" 
            TimelinePosition="TimelinePosition.Top"
            Class="mb-13">
            <MudTimelineItem Color="GetActiveColor(0)" Variant="Variant.Outlined" Size="Size.Medium">
                <ItemContent>
                    <MudAlert Severity="GetActiveSeverity(0)">Select the device type</MudAlert>
                </ItemContent>
                <ItemDot>
                    <MudText>1</MudText>
                </ItemDot>
            </MudTimelineItem>
            <MudTimelineItem Color="GetActiveColor(1)" Variant="Variant.Outlined" Size="Size.Medium">
                <ItemContent>
                    <MudAlert Severity="GetActiveSeverity(1)">Select your server's network adapter</MudAlert>
                </ItemContent>
                <ItemDot>
                    <MudText>2</MudText>
                </ItemDot>
            </MudTimelineItem>
            <MudTimelineItem Color="GetActiveColor(2)" Variant="Variant.Outlined" Size="Size.Medium">
                <ItemContent>
                    <MudAlert Severity="GetActiveSeverity(2)">Enter your WIFI credentials</MudAlert>
                </ItemContent>
                <ItemDot>
                    <MudText>3</MudText>
                </ItemDot>
            </MudTimelineItem>
            <MudTimelineItem Color="GetActiveColor(3)" Variant="Variant.Outlined" Size="Size.Medium">
                <ItemContent>
                    <MudAlert Severity="GetActiveSeverity(3)">Upload credentials to the device</MudAlert>
                </ItemContent>
                <ItemDot>
                    <MudText>4</MudText>
                </ItemDot>
            </MudTimelineItem>
            <MudTimelineItem Color="GetActiveColor(4)" Variant="Variant.Outlined" Size="Size.Medium">
                <ItemContent>
                    <MudAlert Severity="GetActiveSeverity(4)">Configure device's settings</MudAlert>
                </ItemContent>
                <ItemDot>
                    <MudText>5</MudText>
                </ItemDot>
            </MudTimelineItem>
        </MudTimeline>
        <div @onkeydown="HandleKeyDown" style="min-height:500px">
        @switch (_currentStep)
        {
            case 0:
                <SelectDeviceTypeComponent model="model.PreprovisionRequest" ModelChanged="StateHasChanged" />
                break;
            case 1:
                <SelectNetworkComponent model="model.PreprovisionRequest" ModelChanged="StateHasChanged" />
                break;
            case 2:
                <EnterWifiCredentialsComponent model="model.PreprovisionRequest" ModelChanged="StateHasChanged" />
                break;
            case 3:
                <UploadCredentialsComponent model="model" ModelChanged="StateHasChanged" />
                break;
            case 4:
                <ConfigureDeviceComponent CameraId="model.DeviceId ?? Guid.Empty" ModelChanged="StateHasChanged" />
                break;
            default: break;
        }
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CancelAsync" Color="Color.Error">Cancel</MudButton>
        <MudButton OnClick="Back" Color="Color.Primary" Disabled="@IsBackDisabled()">Back</MudButton>
        @if (_currentStep == _maxStep)
        {
            <MudButton OnClick="Finish" Color="Color.Success" Variant="Variant.Filled">Finish</MudButton>
        }
        else
        {
            <MudButton OnClick="Next" Color="Color.Success" Disabled="!IsCurrentStepCompleted()">Next</MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    public IMudDialogInstance? MudDialog { get; set; }

    [Parameter]
    public Guid? ResumeDeviceId { get; set; }

    private int _currentStep = 0;
    private const int _maxStep = 4;

    public AddDeviceWizardStateModel model { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        if (!ResumeDeviceId.HasValue)
        {
            return;
        }

        var resumeState = await _devicePreProvisionService.GetResumeSetupStateAsync(ResumeDeviceId.Value);

        if (resumeState == null)
        {
            _snackbar.Add("Unable to resume device setup.", Severity.Error);
            return;
        }

        model.PreprovisionRequest.DeviceTypeId = resumeState.DeviceTypeId;
        model.PreprovisionRequest.LocalNetworkInfo = resumeState.LocalNetworkInfo;
        model.DeviceId = resumeState.DeviceId;
        _currentStep = 2;

        StateHasChanged();
    }

    private async Task CancelAsync()
    {
        if (!model.DeviceId.HasValue)
        {
            MudDialog?.Cancel();
            return;
        }

        var choice = await ShowPairingCancelDialogAsync();

        if (choice == null || choice == PairingCancelChoice.Back)
        {
            return;
        }

        if (choice == PairingCancelChoice.CancelPairing)
        {
            if (model.DeviceId.HasValue)
            {
                var deleted = await _devicePreProvisionService.CancelPairingAndDeleteDeviceAsync(model.DeviceId.Value);

                if (!deleted)
                {
                    _snackbar.Add("Failed to cancel pairing.", Severity.Error);
                    return;
                }
            }
        }

        MudDialog?.Close(DialogResult.Ok(choice));
    }

    private async Task<PairingCancelChoice?> ShowPairingCancelDialogAsync()
    {
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var parameters = new DialogParameters<PairingCancelDecisionDialog>
        {
            { x => x.DisableContinueLater, model.IsPaired }
        };

        var dialog = await _dialogService.ShowAsync<PairingCancelDecisionDialog>("Cancel Pairing", parameters, options);
        var result = await dialog.Result;

        if (result == null || result.Canceled || result.Data is not PairingCancelChoice choice)
        {
            return PairingCancelChoice.Back;
        }

        return choice;
    }

    private bool IsBackDisabled()
    {
        return _currentStep == 0 || _currentStep == _maxStep || model.IsPaired;
    }

    private Color GetActiveColor(int step)
    {
        if (step == _currentStep  )
        {
            if (IsCurrentStepCompleted())
            {
                return Color.Success;
            }

            return Color.Info;
        }

        return step < _currentStep ? Color.Success : Color.Error;
    }

    private Severity GetActiveSeverity(int step)
    {
        if (step == _currentStep)
        {
            if (IsCurrentStepCompleted())
            {
                return Severity.Success;
            }

            return Severity.Info;
        }

        return step < _currentStep ? Severity.Success : Severity.Error;
    }

    private void Back()
    {
        if (_currentStep > 0)
        {
            _currentStep--;
        }
    }

    private void Next()
    {
        if (_currentStep < _maxStep)
        {
            _currentStep++;
        }
    }

    private void Finish()
    {
        MudDialog?.Close(DialogResult.Ok(model.DeviceId));
    }

    private bool IsCurrentStepCompleted()
    {
        return _currentStep switch
        {
            0 => model.PreprovisionRequest.DeviceTypeId != default,
            1 => model.PreprovisionRequest.LocalNetworkInfo != default,
            2 => !string.IsNullOrEmpty(model.PreprovisionRequest.WifiSSID) && !string.IsNullOrEmpty(model.PreprovisionRequest.WifiPassword),
            3 => model.IsPaired,
            4 => true,
            _ => false
        };
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key != "Enter")
        {
            return;
        }
        if (_currentStep == _maxStep)
        {
            Finish();
        }
        else if (IsCurrentStepCompleted())
        {
            Next();
        }
    }
}

@using CamPortal.Contracts.Abstractions.Services
@using CamPortal.Contracts.Dtos.PreprovisionAttemptDtos
@using CamPortal.Core.Services
@inject IDevicePreProvisionService _deviceProvisionService
@inject IPreprovisionNotifier _preprovisionNotifier
@inject IConfiguration _configuration
@inject ISnackbar _snackbar
@inject IDialogService _dialogService
@inject IJSRuntime _js
@inject ICameraFramesManagerService _cameraFramesManagerService
@implements IAsyncDisposable

@if (_IsAcknowledged)
{
    @if (!_isHandshakeCompleted)
    {
        <MudStack>
            <MudStack Row="true" Justify="Justify.SpaceBetween">
                <MudText Typo="Typo.h4">Upload credentials to the device</MudText>
                <MudTooltip Arrow="true"
                            Placement="Placement.Bottom">
                    <ChildContent>
                        <MudToggleGroup T="bool" SelectionMode="SelectionMode.SingleSelection" @bind-Value="_isQrDisplayed" Color="Color.Primary" FixedContent CheckMark="true">
                            <MudToggleItem SelectedIcon="@Icons.Material.Filled.QrCode2" UnselectedIcon="@Icons.Material.Filled.QrCode2" Value="true" Text="QR Code" />
                            <MudToggleItem SelectedIcon="@Icons.Material.Filled.Code" UnselectedIcon="@Icons.Material.Filled.Code" Value="false" Text="Raw Secrets" />
                        </MudToggleGroup>
                    </ChildContent>
                    <TooltipContent>
                        <MudText>Scan the QR code with your phone after</MudText>
                        <MudText>connecting it to the device's setup Wi-Fi,</MudText>
                        <MudText>or flash the Raw Secrets directly.</MudText>
                    </TooltipContent>
                </MudTooltip>
            </MudStack>
            <MudGrid>
                <MudItem lg="6" Style="display:flex; flex-direction:column;">
                    @if (_isQrDisplayed)
                    {
                        <MudStack Spacing="3" Justify="Justify.Center" Style="flex:1; min-height:0;">
                            <div class="qr-clickable" @onclick="OpenFullscreenQr" title="Click to enlarge">
                                <MudImage Src="@_generatedCredentials.QRCode"
                                          Style="display:block; width:100%; border-radius:8px;" />
                                <div class="qr-clickable-hint">
                                    <MudIcon Icon="@Icons.Material.Filled.Fullscreen" Size="Size.Small" />
                                    <span>Click to enlarge</span>
                                </div>
                            </div>
                            <MudButton StartIcon="@Icons.Material.Filled.ContentCopy"
                                       Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       Size="Size.Large"
                                       FullWidth="true"
                                       OnClick="CopyPayloadUrlAsync"
                                       Disabled="@string.IsNullOrWhiteSpace(_generatedCredentials.QrPayloadUrl)">
                                Copy provisioning URL
                            </MudButton>
                            <MudText Typo="Typo.caption" Align="Align.Center" Style="opacity:0.7;">
                                If your phone can't scan, copy the URL and paste it in the captive portal page on the device.
                            </MudText>
                        </MudStack>
                    }
                    else
                    {
                        <SecretsCodeBlockComponent Model="_generatedCredentials"></SecretsCodeBlockComponent>
                    }
                </MudItem>
                <MudItem lg="6">
                    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="height: 100%;">
                        <MudPaper Elevation="50" Class="pa-5" Outlined="true" Style="height:100%">
                            <MudStack Spacing="5" Justify="Justify.Center" AlignItems="AlignItems.Center" Style="height:100%">
                                <MudStack Spacing="2" AlignItems="AlignItems.Center" Justify="Justify.Center">
                                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Justify="Justify.Center">
                                        <MudText Typo="Typo.h5">Credentials are valid for:</MudText>
                                        <MudText Typo="Typo.h4" Color="Color.Error">@FormatTime(_elapsedSeconds)</MudText>
                                    </MudStack>
                                    <MudButton Disabled="@_isLoading" StartIcon="@Icons.Material.Filled.RestartAlt" Variant="Variant.Filled" Size="Size.Large" Color="Color.Error" OnClick="() => StartProvisioning()">
                                        @if (_isLoading)
                                        {
                                            <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                                            <MudText Class="ms-2">Regenerating Credentials...</MudText>
                                        }
                                        else
                                        {
                                            <MudText>Regenerate Credentials</MudText>
                                        }                           
                                    </MudButton>
                                </MudStack>
                                @if (_isQrDisplayed)
                                {
                                    <MudText Typo="Typo.h5"><b>1.</b> Power the device on. The device LED should be blue, indicating its broadcast of the setup Wi-Fi.</MudText>
                                    <MudText Typo="Typo.h5"><b>2.</b> On your phone, join the Wi-Fi network <b>@_deviceSetupApSsidPrefix<i>XXXX</i></b> using the password <b>@_deviceSetupApPassword</b>. Dismiss any "no internet" warnings.</MudText>
                                    <MudText Typo="Typo.h5"><b>3.</b> Open your phone's browser (Safari / Chrome) and go to <b>@_devicePreprovisioningUrl</b>.</MudText>
                                    <MudText Typo="Typo.h5"><b>4.</b> Tap <b>Scan QR with camera</b> and photograph the QR on the left. After a successful scan the wizard will update.</MudText>
                                }
                                else
                                {
                                    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">
                                        Use the raw secrets only when you can build and flash the firmware yourself. The QR flow is faster for most users.
                                    </MudAlert>
                                }
                            </MudStack>
                        </MudPaper>
                    </MudStack>
                </MudItem>
                @if (!_isQrDisplayed)
                {
                    <MudItem lg="12">
                         <MudPaper Elevation="50" Class="pa-5" Outlined="true" Style="height:100%">
                             <MudStack Spacing="3">
                                <MudText Typo="Typo.h5"><b>1.</b> Open the camera firmware project in <b>PlatformIO</b> or <b>Arduino IDE</b>.</MudText>
                                <MudText Typo="Typo.h5"><b>2.</b> Open <b>include/secrets.h</b>, locate the existing <b>#ifdef HAS_PROVISIONED_SECRETS</b> block (including the <b>#define HAS_PROVISIONED_SECRETS</b> line above it and the closing <b>#endif</b>) and replace only that block with the snippet on the left. Leave the certificate, server ports and any other defines untouched.</MudText>
                                <MudText Typo="Typo.h5"><b>3.</b> Build and flash the firmware. The device boots directly into streaming mode and skips the captive portal.</MudText>
                                <MudText Typo="Typo.h5"><b>4.</b> This wizard will advance automatically once the device completes its first handshake.</MudText>
                             </MudStack>
                         </MudPaper>
                    </MudItem>
                }
            </MudGrid>
        </MudStack>
    }
    else
    {
        <MudPaper Width="500px" Style="height:400px; margin: 0 auto;" Elevation="0">
            <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="height: 100%;" Spacing="5">
                @if (model.IsPaired)
                {
                    <svg class="success-check" viewBox="0 0 52 52" role="img" aria-label="Credentials uploaded">
                        <circle class="success-check__circle" cx="26" cy="26" r="24" fill="none" />
                        <path class="success-check__mark" fill="none" d="M14 27l8 8 16-16" />
                    </svg>
                    <MudText Typo="Typo.h5">Credentials have been successfully uploaded.</MudText>
                }
                else
                {
                    <MudProgressCircular Size="Size.Large" Color="Color.Default" Indeterminate="true" />
                    <MudText Typo="Typo.h5">Pairing...</MudText>
                }             
            </MudStack>
        </MudPaper>
    }
}
else
{
    <MudPaper Width="500px" Style="margin:0 auto">
        <MudStack>
            <MudIcon Color="Color.Error" Icon="@Icons.Material.Filled.Warning" Style="font-size: 10rem; margin:0 auto;"></MudIcon>
            <MudAlert Severity="Severity.Error" Variant="Variant.Filled" NoIcon="true" Class="my-2">
                <ul class="mb-0" style="font-size:1rem">
                    <li>This action will expose your server credentials to anyone who has access to the device during the pre-provisioning process.</li>
                    <li>Make sure you are in a secure environment and that you trust the people around you before proceeding.</li>
                    <li>Do not share your credentials with anyone.</li>
                    <li>These credentials will be valid for a short period, after that they will be invalidated.</li>
                </ul>
            </MudAlert>
            <MudButton Disabled="@_isLoading" Variant="Variant.Filled" Size="Size.Large" Color="Color.Tertiary" OnClick="() => StartProvisioning()">
                @if(_isLoading)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">Creating Credentials...</MudText>
                }
                else
                {
                    <MudText>Acknowledge</MudText>
                }            
            </MudButton>
        </MudStack> 
    </MudPaper>    
}


@code {

    private bool _IsAcknowledged;
    private bool _isQrDisplayed=true;
    private PeriodicTimer? _timer;
    private PreprovisionDetailsDto _generatedCredentials=new();
    private int _elapsedSeconds;
    private int _preprovisionAttemptExpirationMinutes;
    private string _deviceSetupApSsidPrefix = "CamPortal-Setup-";
    private string _deviceSetupApPassword = string.Empty;
    private string _devicePreprovisioningUrl = string.Empty;

    private bool _isLoading;
    private bool _isHandshakeCompleted;

    [Parameter, EditorRequired]
    public AddDeviceWizardStateModel model { get; set; } = default!;

    [Parameter, EditorRequired]
    public EventCallback ModelChanged { get; set; }

    protected override void OnInitialized()
    {
        _preprovisionNotifier.SuccessfulVerification += OnSuccessfulVerification;

        _preprovisionAttemptExpirationMinutes = int.Parse(_configuration.GetSection("Preprovisioning")["AttemptExpirationMinutes"] ?? throw new ArgumentNullException("Preprovisioning:AttemptExpirationMinutes not configured"));
        _deviceSetupApSsidPrefix = _configuration.GetSection("Preprovisioning")["DeviceSetupApSsidPrefix"] ?? _deviceSetupApSsidPrefix;
        _deviceSetupApPassword = _configuration.GetSection("Preprovisioning")["DeviceSetupApPassword"] ?? string.Empty;
        _devicePreprovisioningUrl = _configuration.GetSection("Preprovisioning")["DeviceProvisioningUrl"] ?? string.Empty;
    }

    public async Task StartProvisioning()
    {
        _isLoading = true;
        await ModelChanged.InvokeAsync();

        if (model.DeviceId==null)
        {
            var result = await _deviceProvisionService.StartPreprovisioningAsync(model.PreprovisionRequest);

            if (result==null)
            {
                _snackbar.Add($"Failed to start preprovisioning.", Severity.Error);

                _isLoading = false;
                await ModelChanged.InvokeAsync();

                return;
            }

            model.DeviceId = result.DeviceId;

            _generatedCredentials = result;
        }
        else
        {
            var result = await _deviceProvisionService.StartPreprovisioningForExistingDeviceAsync(model.DeviceId.Value, model.PreprovisionRequest);

            if (result == null)
            {
                _snackbar.Add($"Failed to start preprovisioning for existing device.", Severity.Error);

                _isLoading = false;
                await ModelChanged.InvokeAsync();

                return;
            }

            _generatedCredentials = result;
        }


        _timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        _elapsedSeconds = _preprovisionAttemptExpirationMinutes * 60;

        _ = RunTimerAsync();

        _IsAcknowledged = true;
        _isLoading = false;
    }

    public async ValueTask DisposeAsync()
    {
        if (_timer != null)
        {
            _timer.Dispose();
        }

        _preprovisionNotifier.SuccessfulVerification -= OnSuccessfulVerification;
        _cameraFramesManagerService.FrameProcessed -= OnFrameProcessed;

        await ValueTask.CompletedTask;
    }

    private async Task RunTimerAsync()
    {
        try
        {
            while (await _timer!.WaitForNextTickAsync())
            {
                if (_elapsedSeconds<=0)
                {
                    _ = StartProvisioning();
                    break;
                }

                _elapsedSeconds--;
                await ModelChanged.InvokeAsync();
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private static string FormatTime(int totalSeconds)
    {
        var ts = TimeSpan.FromSeconds(totalSeconds);
        return ts.ToString(@"mm\:ss");
    }

    private async Task OpenFullscreenQr()
    {
        if (string.IsNullOrWhiteSpace(_generatedCredentials.QRCode))
            return;

        var parameters = new DialogParameters
        {
            ["QrCode"] = _generatedCredentials.QRCode,
            ["QrPayloadUrl"] = _generatedCredentials.QrPayloadUrl
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.False,
            FullWidth = true,
            CloseButton = false,
            NoHeader = true,
            CloseOnEscapeKey = true,
            FullScreen = true
        };

        await _dialogService.ShowAsync<FullscreenQrDialog>(string.Empty, parameters, options);
    }

    private async Task CopyPayloadUrlAsync()
    {
        if (string.IsNullOrWhiteSpace(_generatedCredentials.QrPayloadUrl))
            return;

        await _js.InvokeVoidAsync("navigator.clipboard.writeText", _generatedCredentials.QrPayloadUrl);
        _snackbar.Add("Provisioning URL copied to clipboard", Severity.Success);
    }

    private void OnSuccessfulVerification(Guid deviceId)
    {
        if (_generatedCredentials.DeviceId == Guid.Empty || deviceId != _generatedCredentials.DeviceId)
        {
            return;
        }

        if (_timer != null)
        {
            _timer.Dispose();
        }

        _preprovisionNotifier.SuccessfulVerification -= OnSuccessfulVerification;

        _ = InvokeAsync(() =>
        {
            _isHandshakeCompleted = true;

            ModelChanged.InvokeAsync();

            _cameraFramesManagerService.FrameProcessed += OnFrameProcessed;
        });
    }

    private Task OnFrameProcessed(Guid cameraId, byte[] frame)
    {
        if (cameraId != model.DeviceId)
        {
            return Task.CompletedTask;
        }

        _cameraFramesManagerService.FrameProcessed -= OnFrameProcessed;
    
       return InvokeAsync(() =>
       {
           model.IsPaired = true;

           ModelChanged.InvokeAsync();
       });
    }
}

@using CamPortal.Components.Features.CameraStreamsLiveGrid.Components
@using CamPortal.Contracts.Dtos.CameraConfigurationDtos
@using CamPortal.Contracts.Enums
@using SixLabors.ImageSharp.Processing;

@inject ICameraConfigurationService _cameraConfigurationService
@inject ICameraFramesManagerService _cameraFramesManager
@inject IDeviceService _deviceService
@implements IDisposable

<MudText Typo="Typo.h4" Class="mb-3">Configure device</MudText>

<div class="configure-wrapper">
    <MudOverlay Visible="_isApplying"
                Absolute="true"
                DarkBackground="false"
                Style="backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px); z-index: 10; width:102%; left:-10px;">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
    </MudOverlay>

    <MudGrid Spacing="4">
        <MudItem xs="12" md="7">
            <MudStack Spacing="2" Class="camera-stack">
                <MudStack Spacing="2" Row="true" AlignItems="AlignItems.Center">
                    <div style="width:90px; height:350px; position:relative">
                        <MudSlider T="int"
                                   @bind-Value="_verticalSliderRawValue"
                                   @bind-Value:after="RecalculateVerticalSliderValue"
                                   Immediate="false"
                                   Disabled="@(MaxZoomStartY == 0)"
                                   Vertical="true"
                                   Min="0"
                                   Max="@MaxZoomStartY"
                                   ValueLabel="true"
                                   Color="Color.Error"
                                   Style="position:absolute;top: 0;left: -1rem;width: 340px;">
                            <MudText>Vertical Crop Position</MudText>
                        </MudSlider>
                    </div>          
                    <div class="camera-stream-wrapper">
                        <CameraStreamComponent CameraId="CameraId"></CameraStreamComponent>
                    </div>

                    <MudStack Class="zoom-controls" Spacing="1" AlignItems="AlignItems.Center" Justify="Justify.Center">
                        <MudIconButton Icon="@Icons.Material.Filled.ZoomIn" Color="Color.Error" Size="Size.Medium" OnClick="ZoomIn" />
                        <MudText Typo="Typo.caption">@($"{_cameraConfigurationModel.ZoomFactor:F1}x")</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.ZoomOut" Color="Color.Error" Size="Size.Medium" OnClick="ZoomOut" />
                    </MudStack>
                </MudStack>
                <MudSlider T="int"
                            @bind-Value="_cameraConfigurationModel.ZoomStartX"
                            @bind-Value:after="OnConfigurationChanged"
                            Immediate="false"
                            Disabled="@(MaxZoomStartX == 0)"
                            Min="0"
                            Max="@MaxZoomStartX"
                            ValueLabel="true"
                            Color="Color.Error"
                            Style="width: 80%;margin: 0 auto 0.3rem auto;">
                    <MudText>Horizontal Crop Position</MudText>
                </MudSlider>
            </MudStack>
        </MudItem>

        <MudItem xs="12" md="5">
            <MudStack Spacing="3">
                <MudTextField @bind-Value="_cameraConfigurationModel.CameraName"
                              @bind-Value:after="OnConfigurationChanged"
                              Immediate="false"
                              Label="Camera Name"
                              Variant="Variant.Outlined"
                              For="()=>_cameraConfigurationModel.CameraName" />
                <MudSelect T="FlipMode"
                           Label="Flip Mode"
                           Variant="Variant.Outlined"
                           @bind-Value="_cameraConfigurationModel.FlipMode"
                           @bind-Value:after="OnConfigurationChanged"
                           For="@(() => _cameraConfigurationModel.FlipMode)">
                    @foreach (var mode in Enum.GetValues<FlipMode>())
                    {
                        <MudSelectItem Value="@mode">@mode</MudSelectItem>
                    }
                </MudSelect>
                <MudSelect T="CameraAspectRatios"
                           Label="Aspect Ratio"
                           Variant="Variant.Outlined"
                           @bind-Value="_cameraConfigurationModel.CameraAspectRatio"
                           @bind-Value:after="OnConfigurationChanged"
                           For="@(() => _cameraConfigurationModel.CameraAspectRatio)">
                    @foreach (var ratio in Enum.GetValues<CameraAspectRatios>())
                    {
                        <MudSelectItem Value="@ratio">@MiscUtilities.GetDisplayNameAttributeValue(ratio)</MudSelectItem>
                    }
                </MudSelect>
                <div class="slider-row">
                    <MudText Typo="Typo.body2" Class="slider-label">Brightness</MudText>
                    <MudSlider T="float"
                               @bind-Value="_cameraConfigurationModel.Brightness"
                               @bind-Value:after="OnConfigurationChanged"
                               Immediate="false"
                               Min="0f" Max="2f" Step="0.05f"
                               ValueLabel="true"
                               Color="Color.Error" />
                </div>
                <div class="slider-row">
                    <MudText Typo="Typo.body2" Class="slider-label">Contrast</MudText>
                    <MudSlider T="float"
                               @bind-Value="_cameraConfigurationModel.Contrast"
                               @bind-Value:after="OnConfigurationChanged"
                               Immediate="false"
                               Min="0f" Max="2f" Step="0.05f"
                               ValueLabel="true"
                               Color="Color.Error" />
                </div>
                <div class="slider-row">
                    <MudText Typo="Typo.body2" Class="slider-label">Frame Rotation</MudText>
                    <MudSlider T="float"
                               @bind-Value="_cameraConfigurationModel.FrameRotation"
                               @bind-Value:after="OnConfigurationChanged"
                               Immediate="false"
                               Min="-180f" Max="180f" Step="90f"
                               ValueLabel="true"
                               Color="Color.Error" />
                </div>
                <div class="slider-row">
                    <MudText Typo="Typo.body2" Class="slider-label">Sharpen Factor</MudText>
                    <MudSlider T="float"
                               @bind-Value="_cameraConfigurationModel.SharpenFactor"
                               @bind-Value:after="OnConfigurationChanged"
                               Immediate="false"
                               Min="0f" Max="2f" Step="0.05f"
                               ValueLabel="true"
                               Color="Color.Error" />
                </div>
                <MudButton Color="Color.Error" StartIcon="@Icons.Material.Filled.Refresh" OnClick="CreateDefaultCameraConfiguration">
                    Reset to Defaults
                </MudButton>
            </MudStack>
        </MudItem>
    </MudGrid>
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    [Parameter, EditorRequired]
    public Guid CameraId { get; set; } = default!;

    [Parameter, EditorRequired]
    public EventCallback ModelChanged { get; set; }

    [Parameter]
    public bool LoadExistingConfiguration { get; set; }

    private int _cameraFeedWidth;
    private int _cameraFeedHeight;
    private bool _isApplying;
    private int _verticalSliderRawValue;
    private int _defaultWidth;
    private int _defaultHeight;


    private CameraConfigurationModel _cameraConfigurationModel = new()
    {
        CameraName = string.Empty
    };

    private int MaxZoomStartX => Math.Max(0, _defaultWidth - (int)(_cameraFeedWidth / _cameraConfigurationModel.ZoomFactor));
    private int MaxZoomStartY => Math.Max(0, _defaultHeight - (int)(_cameraFeedHeight / _cameraConfigurationModel.ZoomFactor));

    protected override async Task OnInitializedAsync()
    {
        if (CameraId == Guid.Empty)
        {
            throw new ArgumentNullException(nameof(CameraId), "CameraId cannot be empty when configuring the device.");
        }

        var cameraResolution = await _cameraConfigurationService.GetCameraResolutionAsync(CameraId);

        _defaultWidth = cameraResolution?.Width ?? 0;
        _defaultHeight = cameraResolution?.Height ?? 0;

        CalculateActualResolution();

        if (LoadExistingConfiguration)
        {
            var existingConfig = await _cameraConfigurationService.GetCameraConfigurationAsync(CameraId);

            if (existingConfig == null)
            {
                throw new ArgumentNullException(nameof(existingConfig), "No existing configuration found for the provided CameraId.");
            }

            _cameraConfigurationModel = existingConfig;
            _cameraConfigurationModel.DeviceId = CameraId;
            _cameraConfigurationModel.CameraName =await _deviceService.GetDeviceNameAsync(CameraId)??string.Empty;
        }
        else
        {
            await CreateDefaultCameraConfiguration();
        }

        _verticalSliderRawValue = MaxZoomStartY;

        CalculateActualResolution();
    }

    private async Task RecalculateVerticalSliderValue()
    {
        _cameraConfigurationModel.ZoomStartY = MaxZoomStartY - _verticalSliderRawValue;

        await OnConfigurationChanged();
    }

    private async Task OnConfigurationChanged()
    {
        _isApplying = true;
        StateHasChanged();

        var isUpdateSuccessful = await _cameraConfigurationService.UpdateCameraConfigurationAsync(_cameraConfigurationModel);

        if (!isUpdateSuccessful)
        {
            _isApplying = false;
            StateHasChanged();
        }

        CalculateActualResolution();

        _cameraFramesManager.FrameProcessed += OnFrameProcessed;
    }

    private Task OnFrameProcessed(Guid cameraId, byte[] frame)
    {  
        if (cameraId != _cameraConfigurationModel.DeviceId || !_isApplying)
        {
            return Task.CompletedTask;
        }

        _cameraFramesManager.FrameProcessed -= OnFrameProcessed;

        _isApplying = false;
        return InvokeAsync(StateHasChanged);
    }

    private async Task ZoomIn()
    {
        if (_cameraConfigurationModel.ZoomFactor >= 2)
        {
            _cameraConfigurationModel.ZoomFactor = 2;
            return;
        }

        _cameraConfigurationModel.ZoomFactor = MathF.Min(2f, _cameraConfigurationModel.ZoomFactor + 0.2f);
        ClampZoomOffsets();
        await OnConfigurationChanged();
    }

    private async Task ZoomOut()
    {
        if (_cameraConfigurationModel.ZoomFactor <= 1)
        {
            _cameraConfigurationModel.ZoomFactor = 1;
            return;
        }

        _cameraConfigurationModel.ZoomFactor = MathF.Max(1f, _cameraConfigurationModel.ZoomFactor - 0.2f);
        ClampZoomOffsets();
        await OnConfigurationChanged();
    }

    private void ClampZoomOffsets()
    {
        _cameraConfigurationModel.ZoomStartX = Math.Clamp(_cameraConfigurationModel.ZoomStartX, 0, MaxZoomStartX);
        _cameraConfigurationModel.ZoomStartY = Math.Clamp(_cameraConfigurationModel.ZoomStartY, 0, MaxZoomStartY);
    }

    private async Task CreateDefaultCameraConfiguration()
    {
        var totalCameras = await _deviceService.GetTotalCamerasAsync();

        _cameraConfigurationModel = new CameraConfigurationModel()
        {
            DeviceId = CameraId,
            CameraName = $"Camera {totalCameras + 1}",       
        };

        await _cameraConfigurationService.UpdateCameraConfigurationAsync(_cameraConfigurationModel);
    }

    private void CalculateActualResolution()
    {
        (int frameWidth, int frameHeight) = _cameraFramesManager.CalculateActualResolution(
           _defaultWidth,
           _defaultHeight,
           _cameraConfigurationModel.CameraAspectRatio);

        _cameraFeedWidth = frameWidth;
        _cameraFeedHeight = frameHeight;
    }

    private async Task<Guid> ResolveUserIdAsync()
    {
        if (AuthStateTask is null)
        {
            return Guid.Empty;
        }

        var authState = await AuthStateTask;
        return AuthHelper.GetLoggedUserId(authState.User);
    }

    public void Dispose()
    {
        _cameraFramesManager.FrameProcessed -= OnFrameProcessed;
    }
}

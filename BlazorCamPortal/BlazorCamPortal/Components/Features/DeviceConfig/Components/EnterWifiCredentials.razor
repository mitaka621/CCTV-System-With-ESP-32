<MudText Class="mt-1" Typo="Typo.h4" Align="Align.Center">Enter your WIFI credentials</MudText>


<MudPaper Class="pa-4" Width="500px" Style="margin:20px auto" Elevation="20">
    <MudPaper Class="pa-4" Outlined="true">
        <MudStack Row="true" AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Info" />
            <MudText>
                Please enter your WIFI credentials for the interface adapter you have selected on the previous step. The device will connect to that network and will try to reach the server on that interface.
            </MudText>
        </MudStack>
    </MudPaper>
    <MudForm @ref="_form" Model="model" ValidationDelay="0" Class="pt-6">
        <MudStack Spacing="3">
            <MudTextField Label="WIFI SSID"
                            @bind-Value="@_inputSSID"
                            Variant="Variant.Outlined"
                            For="@(() => model.WifiSSID)"
                            Immediate="true"
                            DebounceInterval="10"
                            OnDebounceIntervalElapsed="ValidateWifiSSID" />

            <MudTextField Label="WIFI Password"
                           @bind-Value="@_inputPassword"
                            Variant="Variant.Outlined"
                            For="@(() => model.WifiPassword)"
                            Immediate="true"
                            DebounceInterval="10"
                            OnDebounceIntervalElapsed="ValidateWifiPassword" />
        </MudStack>
    </MudForm>
</MudPaper>
@code {
    private MudForm _form = default!;

    private string _inputPassword=string.Empty;
    private string _inputSSID=string.Empty;

    [Parameter, EditorRequired]
    public PreprovisionDeviceModel model { get; set; } = default!;

    [Parameter, EditorRequired]
    public EventCallback ModelChanged { get; set; }

    protected override void OnInitialized()
    {
        _inputPassword = model.WifiPassword;
        _inputSSID = model.WifiSSID;

        base.OnInitialized();
    }

    public void ValidateWifiSSID(string input)
    {
        if (input.Length<1 || input.Length>60)
        {
            model.WifiSSID = string.Empty;
        }
        else
        {
            model.WifiSSID = input;
        }      

        ModelChanged.InvokeAsync();
    }

    public void ValidateWifiPassword(string input)
    {
        if (input.Length < 6 || input.Length > 200)
        {
            model.WifiPassword = string.Empty;
        }
        else
        {
            model.WifiPassword = input;
        }    

        ModelChanged.InvokeAsync();
    }
}

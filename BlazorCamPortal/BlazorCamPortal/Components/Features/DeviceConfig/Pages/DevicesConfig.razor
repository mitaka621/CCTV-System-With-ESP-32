@page "/camerasConfig"
@using CamPortal.Components.Features.CameraStreamsLiveGrid.Dialogs
@using CamPortal.Contracts.Constants
@using CamPortal.Contracts.Enums
@using Microsoft.AspNetCore.Authorization
@using static MudBlazor.CategoryTypes
@rendermode InteractiveServer

@attribute [Authorize(Roles = Roles.Admin)]

@inject IDeviceService _cameraService
@inject IDialogService _dialogService
@inject IDevicePreProvisionService _devicePairHttpService
@inject IUserTimeZoneService _userTimeZoneService

<PageTitle>Camera Configuration - BlazorCam Portal</PageTitle>

<MudText Typo="Typo.h3" Class="mb-4" Color="Color.Primary">
    <MudIcon Icon="@Icons.Material.Filled.Settings" Class="mr-3" />
    Camera Configuration
</MudText>
<PageLoader IsLoading="_isLoading" Message="Loading cameras...">
    <MudPaper Elevation="4" Class="pa-6 mb-6" Style="position:relative">
        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <div>
                <MudText Typo="Typo.h5" Color="Color.Secondary" Class="mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.Search" Class="mr-2" />
                    Device Preprovisioning
                </MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary">
                    Complete the setup wizard in order to add a new device
                </MudText>
            </div>
            <MudButton Variant="Variant.Filled"
                        Color="Color.Primary"
                        Size="Size.Large"
                        StartIcon="@Icons.Material.Filled.Scanner"
                        OnClick="AddDevice"
                        Disabled="_isLoading">
                Add Device
            </MudButton>
        </MudStack>
    </MudPaper>
    <MudPaper Elevation="4" Class="pa-4 mb-6">
        <MudGrid AlignItems="Center">
            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="_searchTerm"
                              Immediate="true"
                              Label="Search by name or ID"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Clearable="true" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudSelect T="DevicePairStatus"
                           Label="Filter by status"
                           MultiSelection="true"
                           @bind-SelectedValues="_selectedStatuses"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           MultiSelectionTextFunc="@(selected => string.Join(", ", selected.Select(s => MiscUtilities.GetDisplayNameAttributeValue(Enum.Parse<DevicePairStatus>(s)))))">
                    @foreach (var status in Enum.GetValues<DevicePairStatus>())
                    {
                        <MudSelectItem T="DevicePairStatus" Value="@status">
                            @MiscUtilities.GetDisplayNameAttributeValue(status)
                        </MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudSelect T="CameraAspectRatios"
                           Label="Filter by aspect ratio"
                           MultiSelection="true"
                           @bind-SelectedValues="_selectedAspectRatios"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           MultiSelectionTextFunc="@(selected => string.Join(", ", selected.Select(s => MiscUtilities.GetDisplayNameAttributeValue(Enum.Parse<CameraAspectRatios>(s)))))">
                    @foreach (var aspectRatio in Enum.GetValues<CameraAspectRatios>())
                    {
                        <MudSelectItem T="CameraAspectRatios" Value="@aspectRatio">
                            @MiscUtilities.GetDisplayNameAttributeValue(aspectRatio)
                        </MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
        </MudGrid>
        <div class="d-flex justify-end mt-3">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Secondary"
                       StartIcon="@Icons.Material.Filled.FilterAltOff"
                       OnClick="ResetFilters">
                Reset Filters
            </MudButton>
        </div>
    </MudPaper>

    @{
        var filteredCameras = GetFilteredCameras();
        var cameraRows = ChunkIntoRows(filteredCameras);
    }

    <MudText Typo="Typo.h4" Class="mb-4" Color="Color.Secondary">
        <MudIcon Icon="@Icons.Material.Filled.Videocam" Class="mr-2" />
        Cameras (@filteredCameras.Count)
    </MudText>

    @if (filteredCameras.Count == 0)
    {
        <MudPaper Elevation="2" Class="pa-8 text-center">
            <MudIcon Icon="@Icons.Material.Outlined.VideocamOff" Size="Size.Large" Color="Color.Secondary" Class="mb-4" />
            <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mb-2">No Devices Found</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Adjust your search or status filters to see more devices</MudText>
        </MudPaper>
    }
    else
    {
        <Virtualize Items="cameraRows" Context="row" ItemSize="RowHeightPx" OverscanCount="2">
            <div class="camera-config-row">
                @foreach (var camera in row)
                {
                    <div class="camera-config-row-item" @key="camera.Id">
                        <MudCard Elevation="6" Class="camera-config-card">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <div class="d-flex align-center justify-space-between">
                                    <div>
                                        <MudText Typo="Typo.h6">
                                            <MudIcon Icon="@Icons.Material.Filled.Videocam" Size="Size.Small" Class="mr-2" />
                                            @(camera.Name ?? "Unnamed Camera")
                                        </MudText>
                                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="config-truncate">
                                            ID: @camera.Id
                                        </MudText>
                                    </div>
                                    <MudChip T="string" Color="@GetStatusColor(camera.PairStatus)" 
                                            Size="Size.Small" 
                                            Icon="@GetStatusIcon(camera.PairStatus)">
                                        @MiscUtilities.GetDisplayNameAttributeValue(camera.PairStatus)
                                    </MudChip>
                                </div>
                            </CardHeaderContent>
                        </MudCardHeader>
                    
                        <MudCardContent>
                            <MudStack Spacing="2">
                                <div class="d-flex align-center">
                                    <MudIcon Icon="@Icons.Material.Filled.NetworkWifi" Size="Size.Small" Class="mr-2" Color="Color.Secondary" />
                                    <MudText Typo="Typo.body2">
                                        <strong>IP:</strong> @(string.IsNullOrWhiteSpace(camera.Ipv4Address) ? "Unknown" : camera.Ipv4Address)
                                    </MudText>
                                </div>
                                @if (camera.ResolutionWidth.HasValue && camera.ResolutionHeight.HasValue && camera.ResolutionWidth > 0)
                                {
                                    <div class="d-flex align-center">
                                        <MudIcon Icon="@Icons.Material.Filled.AspectRatio" Size="Size.Small" Class="mr-2" Color="Color.Secondary" />
                                        <MudText Typo="Typo.body2">
                                            <strong>Resolution:</strong> @camera.ResolutionWidth x @camera.ResolutionHeight
                                        </MudText>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(camera.FirmwareVersion))
                                {
                                    <div class="d-flex align-center">
                                        <MudIcon Icon="@Icons.Material.Filled.Memory" Size="Size.Small" Class="mr-2" Color="Color.Secondary" />
                                        <MudText Typo="Typo.body2">
                                            <strong>Firmware:</strong> @camera.FirmwareVersion
                                        </MudText>
                                    </div>
                                }
                                <div class="d-flex align-center">
                                    <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="mr-2" Color="Color.Secondary" />
                                    <MudText Typo="Typo.body2">
                                        <strong>Added:</strong> @_userTimeZoneService.ToLocal(camera.CreatedAt).ToString("MMM dd, yyyy")
                                    </MudText>
                                </div>
                                @if (camera.UpdatedAt.HasValue)
                                {
                                    <div class="d-flex align-center">
                                        <MudIcon Icon="@Icons.Material.Filled.Update" Size="Size.Small" Class="mr-2" Color="Color.Secondary" />
                                        <MudText Typo="Typo.body2">
                                            <strong>Updated:</strong> @_userTimeZoneService.ToLocal(camera.UpdatedAt.Value).ToString("MMM dd, yyyy HH:mm")
                                        </MudText>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(camera.Fingerprint))
                                {
                                    <MudTooltip Text="@camera.Fingerprint">
                                        <div class="d-flex align-center">
                                            <MudIcon Icon="@Icons.Material.Filled.Fingerprint" Size="Size.Small" Class="mr-2" Color="Color.Secondary" />
                                            <MudText Typo="Typo.body2">
                                                <strong>Fingerprint:</strong> @(camera.Fingerprint)
                                            </MudText>
                                        </div>
                                    </MudTooltip>
                                }
                            </MudStack>
                        </MudCardContent>
                    
                        <MudCardActions Class="d-flex justify-space-between">
                            @if (camera.PairStatus != DevicePairStatus.Removed)
                            {
                                @if (camera.PairStatus == DevicePairStatus.PairingPending)
                                {
                                    <MudButton StartIcon="@Icons.Material.Filled.PlayArrow"
                                             Color="Color.Primary"
                                             Size="Size.Small"
                                             Variant="Variant.Filled"
                                             OnClick="() => ResumeSetup(camera)">
                                        Resume Setup
                                    </MudButton>
                                }
                                else
                                {
                                    <MudButton StartIcon="@Icons.Material.Filled.Edit" 
                                             Color="Color.Secondary" 
                                             Size="Size.Small"
                                             Variant="Variant.Text"
                                               OnClick="() => ConfigureCamera(camera.Id)">
                                        Configure
                                    </MudButton>
                                }
                                <MudButton StartIcon="@Icons.Material.Filled.Delete" 
                                         Color="Color.Error" 
                                         Size="Size.Small"
                                         Variant="Variant.Text"
                                           OnClick="() => ShowForgetDialog(camera)">
                                    Forget
                                </MudButton>
                            }
                            else
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Device forgotten</MudText>
                                <MudButton StartIcon="@Icons.Material.Filled.Restore" 
                                         Color="Color.Primary" 
                                         Size="Size.Small"
                                         Variant="Variant.Text"
                                           OnClick="() => RestoreCamera(camera.Id)">
                                    Restore
                                </MudButton>
                            }
                        </MudCardActions>
                    </MudCard>
                    </div>
                }
            </div>
        </Virtualize>
    }
</PageLoader>

<style>
    .blurry-background {
        backdrop-filter: blur(10px);
    }

    .camera-config-row {
        display: flex;
        gap: 16px;
        height: 320px;
        margin-bottom: 16px;
    }

    .camera-config-row-item {
        flex: 0 1 calc(33.333% - 11px);
        max-width: calc(33.333% - 11px);
        min-width: 0;
    }

    .camera-config-card {
        height: 100%;
        display: flex;
        flex-direction: column;
    }

        .camera-config-card .mud-card-content {
            flex: 1 1 auto;
            overflow: hidden;
        }

        .camera-config-card .mud-card-actions {
            margin-top: auto;
        }

        .camera-config-card .mud-card-content .d-flex {
            min-width: 0;
        }

            .camera-config-card .mud-card-content .d-flex .mud-typography {
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
                min-width: 0;
            }

    .config-truncate {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 100%;
        display: block;
    }
</style>

@code {
	bool _isLoading = true;
	List<CameraDisplayModel> cameraDisplayModels = new();
	List<Guid>? foundDeviceIds;

	private const int CamerasPerRow = 3;
	private const float RowHeightPx = 336f;

	private string _searchTerm = string.Empty;
	private IEnumerable<DevicePairStatus> _selectedStatuses = new HashSet<DevicePairStatus>
	{
		DevicePairStatus.PairingPending,
		DevicePairStatus.Paired
	};

	private IEnumerable<CameraAspectRatios> _selectedAspectRatios = Enum.GetValues<CameraAspectRatios>().ToHashSet();

	protected override async Task OnInitializedAsync()
	{
		_isLoading = true;
		try
		{
			cameraDisplayModels = await _cameraService.GetAllCamerasAsync();
		}
		finally
		{
			_isLoading = false;
		}
	}

	private List<CameraDisplayModel> GetFilteredCameras()
	{
		return cameraDisplayModels
			.Where(c => _selectedStatuses.Contains(c.PairStatus))
			.Where(c => !c.AspectRatio.HasValue || _selectedAspectRatios.Contains(c.AspectRatio.Value))
			.Where(c => string.IsNullOrWhiteSpace(_searchTerm)
				|| (c.Name?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false)
				|| c.Id.ToString().Contains(_searchTerm, StringComparison.OrdinalIgnoreCase))
			.OrderBy(c => GetStatusOrder(c.PairStatus))
			.ThenBy(c => c.Name)
			.ToList();
	}

	private void ResetFilters()
	{
		_searchTerm = string.Empty;
		_selectedStatuses = new HashSet<DevicePairStatus>
		{
			DevicePairStatus.PairingPending,
			DevicePairStatus.Paired
		};
		_selectedAspectRatios = Enum.GetValues<CameraAspectRatios>().ToHashSet();
	}

	private List<List<CameraDisplayModel>> ChunkIntoRows(List<CameraDisplayModel> cameras)
	{
		var rows = new List<List<CameraDisplayModel>>();

		for (int i = 0; i < cameras.Count; i += CamerasPerRow)
		{
			rows.Add(cameras.GetRange(i, Math.Min(CamerasPerRow, cameras.Count - i)));
		}

		return rows;
	}

	private int GetStatusOrder(DevicePairStatus status)
	{
		return status switch
		{
			DevicePairStatus.PairingPending => 0,
			DevicePairStatus.Paired => 1,
			DevicePairStatus.Removed => 2,
			_ => 3
		};
	}

	private async Task ConfigureCamera(Guid cameraId)
	{
		var parameters = new DialogParameters
		{
			["CameraId"] = cameraId
		};

		var options = new DialogOptions
		{
			CloseOnEscapeKey = true,
			MaxWidth = MaxWidth.Large,
			FullWidth = true,
			Position = DialogPosition.TopCenter,
			BackdropClick = false,
			BackgroundClass = "blurry-background"
		};

		var dialog = await _dialogService.ShowAsync<ConfigureCameraDialog>(null, parameters, options);

		await dialog.Result;

		cameraDisplayModels = await _cameraService.GetAllCamerasAsync();
	}

	private async Task AddDevice()
	{
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Large,
            FullWidth = true,
            Position = DialogPosition.TopCenter,
            BackdropClick = false,
            BackgroundClass = "blurry-background"

        };

        var dialog = await _dialogService.ShowAsync<AddDeviceDialog>(null,options);

        await dialog.Result;

        cameraDisplayModels = await _cameraService.GetAllCamerasAsync();
	}

    private async Task ResumeSetup(CameraDisplayModel camera)
    {
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Large,
            FullWidth = true,
            Position = DialogPosition.TopCenter,
            BackdropClick = false,
            BackgroundClass = "blurry-background"
        };

        var parameters = new DialogParameters<AddDeviceDialog>
        {
            { x => x.ResumeDeviceId, camera.Id }
        };

        var dialog = await _dialogService.ShowAsync<AddDeviceDialog>(null, parameters, options);

        await dialog.Result;

        cameraDisplayModels = await _cameraService.GetAllCamerasAsync();
    }

	private async Task ForgetCamera(Guid cameraId)
	{
		await _cameraService.ChangeStatusAndInvalidateCameraAsync(cameraId, DevicePairStatus.Removed);

		var camera = cameraDisplayModels.FirstOrDefault(x => x.Id == cameraId);
		if (camera != null)
		{
			camera.PairStatus = DevicePairStatus.Removed;
		}

		StateHasChanged();
	}

	private async Task RestoreCamera(Guid cameraId)
	{
		await _cameraService.ChangeStatusAndInvalidateCameraAsync(cameraId, DevicePairStatus.Paired);

		var camera = cameraDisplayModels.FirstOrDefault(x => x.Id == cameraId);
		if (camera != null)
		{
			camera.PairStatus = DevicePairStatus.Paired;
		}

		StateHasChanged();
	}

	private Color GetStatusColor(DevicePairStatus status)
	{
		return status switch
		{
			DevicePairStatus.Paired => Color.Success,
            DevicePairStatus.PairingPending => Color.Warning,
            DevicePairStatus.Removed => Color.Error,
			_ => Color.Default
		};
	}

	private string GetStatusIcon(DevicePairStatus status)
	{
		return status switch
		{
			DevicePairStatus.Paired => Icons.Material.Filled.CheckCircle,
            DevicePairStatus.PairingPending => Icons.Material.Filled.Sync,
            DevicePairStatus.Removed => Icons.Material.Filled.Block,
			_ => Icons.Material.Filled.Help
		};
	}

    private async Task ShowForgetDialog(CameraDisplayModel camera)
    {
        bool? result = await _dialogService.ShowMessageBox(
            "Confirm Delete",
            (MarkupString)$"Are you sure you want to forget <b>{camera.Name??camera.Id.ToString()}</b>?",
            yesText: "Yes",
            cancelText: "Cancel"
        );

        if (result == true)
        {
            await ForgetCamera(camera.Id);
        }
    }
}

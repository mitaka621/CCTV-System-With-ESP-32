@page "/system/settings"
@rendermode InteractiveServer

@using CamPortal.Contracts.Constants
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize(Roles = Roles.Admin)]

<PageTitle>Settings - BlazorCam Portal</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudStack Spacing="4">
        <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Tune" Color="Color.Primary" />
            <MudText Typo="Typo.h4">Settings</MudText>
        </MudStack>

        <MudGrid Spacing="3">
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="4">
                    <MudCardContent>
                        <MudStack AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Devices" Size="Size.Large" Color="Color.Primary" />
                            <MudText Typo="Typo.h6">Device Types</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                                Manage the device categories used in the catalog.
                            </MudText>
                        </MudStack>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" Href="/system/settings/deviceTypes">
                            Open
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="4">
                    <MudCardContent>
                        <MudStack AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.PeopleAlt" Size="Size.Large" Color="Color.Primary" />
                            <MudText Typo="Typo.h6">Users</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                                Add or remove users and edit their roles.
                            </MudText>
                        </MudStack>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" Href="/system/settings/users">
                            Open
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="4">
                    <MudCardContent>
                        <MudStack AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.AutoDelete" Size="Size.Large" Color="Color.Primary" />
                            <MudText Typo="Typo.h6">Video Retention</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                                Configure when encoded videos and camera chunks are removed.
                            </MudText>
                        </MudStack>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" Href="/system/settings/retention">
                            Open
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        </MudGrid>
    </MudStack>
</MudContainer>

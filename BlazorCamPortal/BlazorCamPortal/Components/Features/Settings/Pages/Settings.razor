@page "/system/settings"
@rendermode InteractiveServer

<h3>Settings</h3>

<MudContainer MaxWidth="MaxWidth.Large">
    <MudGrid Spacing="5" Justify="Justify.Center">
        <MudItem>
            <MudButton Href="/system/settings/deviceTypes">
                <MudPaper Height="140px" Width="140px">
                    <MudIcon Icon="@Icons.Material.Filled.Devices" Size="Size.Large" Color="Color.Primary" Class="mt-5 mb-2" />
                    <MudText Typo="Typo.h6" Align="Align.Center" Class="mt-5">Device Types</MudText>
                </MudPaper>
            </MudButton>          
        </MudItem>
        <MudItem>
            <MudPaper Height="140px" Width="140px" />
        </MudItem>
        <MudItem>
            <MudPaper Height="140px" Width="140px" />
        </MudItem>
    </MudGrid>
</MudContainer>

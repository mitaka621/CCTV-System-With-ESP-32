@using MudBlazor
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject IDialogService DialogService

<MudDialog>
    <DialogContent>
        <div class="fullscreen-camera">
            <div class="fullscreen-header">
                <MudText Typo="Typo.h5" Color="Color.Surface">
                    @GetCameraDisplayName()
                </MudText>
                <div class="fullscreen-controls">
                    <MudIconButton Icon="@Icons.Material.Filled.Close" 
                                   Color="Color.Surface" 
                                   Size="Size.Medium"
                                   Class="close-button"
                                   OnClick="CloseDialog" />
                </div>
            </div>
            
            <div class="fullscreen-video-container">
                <img id="fullscreen-@Camera.Id"
                     src="@GetStreamUrl()"
                     alt="@GetCameraDisplayName()"
                     class="fullscreen-stream"
                     draggable="false" />
            </div>
            

        </div>
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter] 
    public IMudDialogInstance? MudDialog { get; set; }

    [Parameter] 
    public CameraDisplayModel Camera { get; set; } = default!;

    private bool _hasRenderedInteractively;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _hasRenderedInteractively = true;
            await JS.InvokeVoidAsync("forceDialogFullscreen");
        }
    }

    private void CloseDialog()
    {
        MudDialog?.Close();
    }

    private string GetStreamUrl() => $"/api/cameras/{Camera.Id}/stream";

    private string GetCameraDisplayName()
    {
        if (!string.IsNullOrEmpty(Camera.Name))
            return Camera.Name;
        
        return $"{Camera.Id}";
    }

    public async ValueTask DisposeAsync()
    {
        if (!_hasRenderedInteractively)
            return;

        try
        {
            await JS.InvokeVoidAsync("stopCameraStreamById", $"fullscreen-{Camera.Id}");
        }
        catch (JSDisconnectedException) { }
        catch (TaskCanceledException) { }
        catch (InvalidOperationException) { }
    }
}

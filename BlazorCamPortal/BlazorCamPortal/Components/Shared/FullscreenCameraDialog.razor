@using MudBlazor
@implements IDisposable
@inject IJSRuntime JS
@inject IConfiguration _configuration
@inject IDialogService DialogService

<MudDialog>
    <DialogContent>
        <div class="fullscreen-camera">
            <div class="fullscreen-header">
                <MudText Typo="Typo.h5" Color="Color.Surface">
                    @GetCameraDisplayName()
                </MudText>
                <div class="fullscreen-controls">
                    <MudIconButton Icon="@Icons.Material.Filled.Close" 
                                   Color="Color.Surface" 
                                   Size="Size.Medium"
                                   Class="close-button"
                                   OnClick="CloseDialog" />
                </div>
            </div>
            
            <div class="fullscreen-video-container">
                <canvas id="fullscreen-@Camera.Id" 
                        width="1920" 
                        height="1080"
                        class="fullscreen-canvas">
                </canvas>
            </div>
            

        </div>
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter] 
    public IMudDialogInstance? MudDialog { get; set; }

    [Parameter] 
    public CameraDisplayModel Camera { get; set; } = default!;

    [Parameter] 
    public ICameraFramesManagerService CameraFramesManagerService { get; set; } = default!;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Force dialog to be fullscreen via JavaScript as backup
            await JS.InvokeVoidAsync("forceDialogFullscreen");
            
            await OnFrameAdded(Camera.Id, VideoChunkUtilities.GetDefaultFrame(_configuration));
            
            CameraFramesManagerService.FrameProcessed += OnFrameAdded;
        }
    }

    private async Task OnFrameAdded(Guid cameraId, byte[] frame)
    {
        if (cameraId != Camera.Id) return;

        try
        {
            using var stream = new MemoryStream(frame);
            using var streamRef = new DotNetStreamReference(stream);

            await JS.InvokeVoidAsync("drawFrame", $"fullscreen-{cameraId}", streamRef);
        }
        catch (TaskCanceledException)
        {
        }
        catch (ObjectDisposedException)
        {
        }
    }

    private void CloseDialog()
    {
        MudDialog?.Close();
    }

    private string GetCameraDisplayName()
    {
        if (!string.IsNullOrEmpty(Camera.Name))
            return Camera.Name;
        
        return $"{Camera.Id}";
    }

    public void Dispose()
    {
        CameraFramesManagerService.FrameProcessed -= OnFrameAdded;
    }
}

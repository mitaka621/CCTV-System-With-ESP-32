  "TCPServerConfig": {
    "Port": 7000,
    "NumberOfBufferRawFrames": 100
  },
  "CertificatesConfig": {
    "CertificateAutoGeneratedPassword": "6jmraiUlPiIK0HYc"
  },
  "ServerIdentity": {
    "PrivateKeyPath": "data/server-identity.pem"
